---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import WorkIndexItem from "../../components/WorkIndexItem.astro";
import { caseStudies } from "../../data/caseStudies";
---

<BaseLayout
  title="Selected work | Cookies & Tokens"
  description="Case studies from Cookies & Tokens across restaurants, retail, medical offices, and real estate lead generation."
>
  <Nav />

  <main>
    <section class="work-index" data-work-index aria-labelledby="work-index-title">
      <header class="work-index__hero" data-work-index-intro>
        <a href="/" class="work-index__back" data-cursor="link">Back to site</a>
        <p class="eyebrow work-index__eyebrow">Selected Work</p>
        <div class="work-index__headline">
          <h1 id="work-index-title">Proof that the work moved something.</h1>
          <p>
            Four examples across owned channels, paid media, lead generation,
            loyalty, websites, and digital experience.
          </p>
        </div>
      </header>

      <div class="work-index__list" data-work-index-list>
        {
          caseStudies.map((study, index) => (
            <WorkIndexItem study={study} variant="full" index={index} />
          ))
        }
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .work-index {
    min-height: 100dvh;
    padding-inline: var(--spacing-gutter);
    padding-block: clamp(8rem, 18vh, 13rem) clamp(5rem, 12vh, 9rem);
    color: var(--color-ink);
    background:
      linear-gradient(
        90deg,
        transparent 0,
        transparent calc(100% - var(--spacing-gutter)),
        color-mix(in srgb, var(--color-navy) 5%, transparent)
          calc(100% - var(--spacing-gutter)),
        color-mix(in srgb, var(--color-navy) 5%, transparent) 100%
      ),
      var(--color-cream);
  }

  .work-index__hero,
  .work-index__list {
    max-width: 88rem;
    margin-inline: auto;
  }

  .work-index__back {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    margin-bottom: clamp(2rem, 5vw, 4rem);
    color: var(--color-ink-muted);
    font-size: 0.86rem;
    font-weight: 600;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-soft);
  }

  .work-index__back::before {
    content: "";
    width: 1.2rem;
    height: 1px;
    margin-right: 0.65rem;
    background: currentColor;
  }

  .work-index__back:hover,
  .work-index__back:focus-visible {
    color: var(--color-ink);
  }

  .work-index__eyebrow {
    margin: 0 0 1rem;
    color: var(--color-purple-deep);
  }

  .work-index__headline {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.36fr);
    gap: clamp(2rem, 6vw, 7rem);
    align-items: end;
  }

  .work-index__headline h1 {
    max-width: 13ch;
    margin: 0;
    font-size: clamp(3rem, 8vw, 7.2rem);
    line-height: 0.94;
    letter-spacing: -0.055em;
  }

  .work-index__headline p {
    max-width: 31rem;
    margin: 0 0 0.5rem;
    color: var(--color-ink-muted);
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    line-height: 1.65;
    text-wrap: pretty;
  }

  .work-index__list {
    margin-top: clamp(3.5rem, 8vw, 6.5rem);
  }

  @media (max-width: 900px) {
    .work-index__headline {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>

<script>
  import { reveal } from "../../lib/reveal";

  const root = document.querySelector<HTMLElement>("[data-work-index]");
  if (root) {
    reveal(root.querySelector("[data-work-index-intro]"), { trigger: root, y: 24 });
    reveal(root.querySelectorAll("[data-work-item]"), {
      trigger: root.querySelector("[data-work-index-list]"),
      stagger: 0.1,
    });
  }
</script>
