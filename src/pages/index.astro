---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Manifesto from "../components/Manifesto.astro";
import CollisionScene from "../components/CollisionScene.astro";
import CookieSide from "../components/CookieSide.astro";
import Offering from "../components/Offering.astro";
import TokenSide from "../components/TokenSide.astro";
import Overlap from "../components/Overlap.astro";
import Process from "../components/Process.astro";
import Proof from "../components/Proof.astro";
import About from "../components/About.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";

// ── The three things we do, each its own section (Creative / Growth / Software).
// Tone + accent alternate down the page for rhythm.

const creative = {
  id: "creative",
  eyebrow: "What We Do / 01",
  titleLead: "Creative",
  titleAccent: "that means something.",
  sub: "Brand, content, and the strategy behind both. Deep creative experience sets the point of view, then AI lets us explore wider and ship more without losing the taste that makes it yours.",
  tone: "light" as const,
  accent: "purple" as const,
  cards: [
    {
      number: "01",
      title: "Brand & Identity",
      desc: "Strategy, naming, visual identity, and the guidelines that hold it together. The system that makes you instantly recognisable and hard to copy.",
      tags: ["Strategy", "Naming", "Visual Identity", "Guidelines"],
    },
    {
      number: "02",
      title: "Content & Copy",
      desc: "Copy that earns attention and visuals with a point of view. Built as a system so the voice stays consistent at volume, across every channel.",
      tags: ["Copywriting", "Social", "Content Systems", "Production"],
    },
    {
      number: "03",
      title: "Creative Strategy",
      desc: "The thinking before the making. Positioning, messaging, and the creative concepts that decide what the work should say before we say it.",
      tags: ["Positioning", "Messaging", "Concepts", "Direction"],
    },
    {
      number: "04",
      title: "Design & Production",
      desc: "Campaigns, assets, and brand collateral, concept to delivery. Human art direction, AI in the production pipeline, so volume never costs you quality.",
      tags: ["Campaigns", "Art Direction", "Assets", "Always-On"],
    },
  ],
};

const growth = {
  id: "growth",
  eyebrow: "What We Do / 02",
  titleLead: "Growth across",
  titleAccent: "every channel.",
  sub: "We drive growth through the channels that actually move the needle, organic and paid working as one engine. Real marketing experience, supercharged by AI to test more, learn faster, and scale what works.",
  tone: "dark" as const,
  accent: "teal" as const,
  cards: [
    {
      number: "01",
      title: "Organic Growth",
      desc: "Growth hacking the channels most agencies ignore. Community and local group posting, partnerships, and the scrappy, compounding tactics that build an audience without a media budget.",
      tags: ["Growth Hacking", "Community", "Local", "Partnerships"],
    },
    {
      number: "02",
      title: "Email & Lifecycle",
      desc: "List building, automated flows, and campaigns that turn subscribers into revenue. The owned channel you control, working while you sleep.",
      tags: ["List Building", "Flows", "Campaigns", "Retention"],
    },
    {
      number: "03",
      title: "PR & Earned Media",
      desc: "Stories worth covering and the outreach to land them. Press, features, and earned attention that buys credibility paid media can't.",
      tags: ["Press", "Outreach", "Features", "Reputation"],
    },
    {
      number: "04",
      title: "Paid Media",
      desc: "Paid social and search that scale profitably. We build the creative, run the experiments, and let AI optimise the spend so every dollar works harder.",
      tags: ["Paid Social", "Search", "Creative Testing", "Optimisation"],
    },
  ],
};

const software = {
  id: "software",
  eyebrow: "What We Do / 03",
  titleLead: "Software,",
  titleAccent: "built to ship.",
  sub: "Full web and mobile apps, custom software, and AI agents that run your workflows. Engineers with deep experience, AI woven through the build, so you get production software faster, not slideware.",
  tone: "light" as const,
  accent: "purple" as const,
  cards: [
    {
      number: "01",
      title: "Web Apps",
      desc: "Full web applications, front to back. Marketing sites, dashboards, and complete products, designed and engineered to perform and scale.",
      tags: ["Frontend", "Backend", "Dashboards", "Performance"],
    },
    {
      number: "02",
      title: "Mobile Apps",
      desc: "Native iOS and Android, or cross-platform when it makes sense. From first build to app store, with the polish users expect on their phone.",
      tags: ["iOS", "Android", "Cross-Platform", "App Store"],
    },
    {
      number: "03",
      title: "Custom Software & SaaS",
      desc: "When off-the-shelf falls short, we build it. Bespoke internal tools, integrations, and full SaaS products engineered around how your business actually runs.",
      tags: ["Internal Tools", "Integrations", "SaaS", "APIs"],
    },
    {
      number: "04",
      title: "AI Agents & Automation",
      desc: "We stand up AI agents to handle the workflows that eat your team's time. From support and ops to research and reporting, working day and night.",
      tags: ["AI Agents", "Workflows", "Automation", "Ops"],
    },
  ],
};
---

<BaseLayout>
  <Nav />

  <main>
    <Hero />
    <Manifesto />
    <CollisionScene />
    <CookieSide />
    <Offering {...creative} />
    <Offering {...growth} />
    <Offering {...software} />
    <TokenSide />
    <Overlap />
    <Process />
    <Proof />
    <About />
    <CTA />
  </main>

  <Footer />
</BaseLayout>
