---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import CollisionScene from "../components/CollisionScene.astro";
import CookieSide from "../components/CookieSide.astro";
import Offering from "../components/Offering.astro";
import SelectedWork from "../components/SelectedWork.astro";
import TokenSide from "../components/TokenSide.astro";
import Overlap from "../components/Overlap.astro";
import Process from "../components/Process.astro";
import Proof from "../components/Proof.astro";
import About from "../components/About.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";

// ── The three things we do, each its own section (Creative / Growth / Software).
// Tone + accent alternate down the page for rhythm.

const creative = {
  id: "creative",
  eyebrow: "What We Do / 01",
  titleLead: "Creative with",
  titleAccent: "a point of view.",
  sub: "Brand, content, and the strategy behind both. People with real creative experience set the direction. AI lets us produce more of it without thinning the quality.",
  tone: "light" as const,
  accent: "purple" as const,
  cards: [
    {
      number: "01",
      title: "Brand & Identity",
      desc: "Strategy, naming, visual identity, and the system that holds it together. The part that makes you recognizable and hard to copy.",
      tags: ["Strategy", "Naming", "Visual Identity", "Guidelines"],
    },
    {
      number: "02",
      title: "Content & Copy",
      desc: "Copy that earns attention and visuals with a point of view, built as a system so the voice stays consistent across every channel at volume.",
      tags: ["Copywriting", "Social", "Content Systems", "Production"],
    },
    {
      number: "03",
      title: "Creative Strategy",
      desc: "The thinking before the making. Positioning, messaging, and the concepts that decide what the work should say before we say it.",
      tags: ["Positioning", "Messaging", "Concepts", "Direction"],
    },
    {
      number: "04",
      title: "Design & Production",
      desc: "Campaigns and brand collateral, concept to delivery. Human art direction with AI in the production pipeline, so volume never costs you quality.",
      tags: ["Campaigns", "Art Direction", "Assets", "Always On"],
    },
  ],
};

const growth = {
  id: "growth",
  eyebrow: "What We Do / 02",
  titleLead: "Growth across every",
  titleAccent: "channel that pays.",
  sub: "Owned, earned, and paid, run as one engine instead of three disconnected line items. We test fast, kill what fails, and put budget behind what works.",
  tone: "dark" as const,
  accent: "teal" as const,
  cards: [
    {
      number: "01",
      title: "Organic & Community",
      desc: "The compounding channels most agencies skip. Community posting, local groups, and partnerships that build an audience before you spend a dollar on media.",
      tags: ["Growth Hacking", "Community", "Local", "Partnerships"],
    },
    {
      number: "02",
      title: "Email & Lifecycle",
      desc: "List building and automated flows that turn subscribers into revenue while you sleep. The one channel you actually own.",
      tags: ["List Building", "Flows", "Campaigns", "Retention"],
    },
    {
      number: "03",
      title: "PR & Earned Media",
      desc: "Stories worth covering and the outreach to land them. The credibility you cannot buy with ad spend.",
      tags: ["PR", "Outreach", "Earned Media", "Credibility"],
    },
    {
      number: "04",
      title: "Paid Media",
      desc: "Paid social and search that scale profitably. We build the creative, run the tests, and put spend where the return is.",
      tags: ["Paid Social", "Search", "Creative Testing", "ROAS"],
    },
  ],
};

const software = {
  id: "software",
  eyebrow: "What We Do / 03",
  titleLead: "Software",
  titleAccent: "built to ship.",
  sub: "Web and mobile apps, custom internal tools, and AI agents that run your workflows. Real engineers, AI in the build, production software at the end.",
  tone: "light" as const,
  accent: "purple" as const,
  cards: [
    {
      number: "01",
      title: "Web Apps",
      desc: "Full applications, front to back. Marketing sites, dashboards, and complete products engineered to scale.",
      tags: ["Frontend", "Backend", "Dashboards", "Performance"],
    },
    {
      number: "02",
      title: "Mobile Apps",
      desc: "Native iOS and Android, or cross platform when it fits. From first build to the app store.",
      tags: ["iOS", "Android", "Cross Platform", "App Store"],
    },
    {
      number: "03",
      title: "Custom Software & SaaS",
      desc: "When off the shelf falls short, we build it. Internal tools, integrations, and full SaaS products shaped around how your business actually runs.",
      tags: ["Internal Tools", "Integrations", "SaaS", "APIs"],
    },
    {
      number: "04",
      title: "AI Agents & Automation",
      desc: "We stand up agents that handle the work eating your team's hours. Support, ops, research, reporting. Running day and night.",
      tags: ["AI Agents", "Workflows", "Automation", "Ops"],
    },
  ],
};
---

<BaseLayout>
  <Nav />

  <main>
    <Hero />
    <CollisionScene />
    <CookieSide />
    <Offering {...creative} />
    <Offering {...growth} />
    <Offering {...software} />
    <SelectedWork />
    <TokenSide />
    <Overlap />
    <Process />
    <Proof />
    <About />
    <CTA />
  </main>

  <Footer />
</BaseLayout>
