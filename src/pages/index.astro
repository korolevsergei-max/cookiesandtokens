---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import CollisionScene from "../components/CollisionScene.astro";
import CookieSide from "../components/CookieSide.astro";
import OfferingCreative from "../components/OfferingCreative.astro";
import OfferingGrowth from "../components/OfferingGrowth.astro";
import OfferingSoftware from "../components/OfferingSoftware.astro";
import About from "../components/About.astro";
import Industries from "../components/Industries.astro";
import SelectedWork from "../components/SelectedWork.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";

// ── Three growth levers, each its own section (Brand / Channels / Digital Experience).
// Tone + accent alternate down the page for rhythm.

const creative = {
  id: "creative",
  eyebrow: "Growth Lever 01 / Brand",
  titleLead: "Creative that pulls",
  titleAccent: "its weight.",
  sub: "A recognizable brand does some of the selling and lowers your cost per customer. Senior creatives set the direction and every piece earns its keep.",
  tone: "light" as const,
  accent: "purple" as const,
  cards: [
    {
      number: "01",
      title: "Brand & Identity",
      desc: "Positioning, naming, and a visual system that makes you recognizable and hard to copy. Recognition is cheaper than reach.",
      tags: ["Strategy", "Naming", "Visual Identity", "Guidelines"],
    },
    {
      number: "02",
      title: "Content & Copy",
      desc: "Copy and content built as a system, so the voice holds across every menu, feed, and shelf.",
      tags: ["Copywriting", "Social", "Content Systems", "Production"],
    },
    {
      number: "03",
      title: "Creative Strategy",
      desc: "The thinking before the making. What to say, to whom, and in what order, decided before a dollar is spent.",
      tags: ["Positioning", "Messaging", "Concepts", "Direction"],
    },
    {
      number: "04",
      title: "Design & Production",
      desc: "Campaigns and collateral from concept to delivery, at the volume your channels actually need.",
      tags: ["Campaigns", "Art Direction", "Assets", "Always On"],
    },
  ],
};

const growth = {
  id: "growth",
  eyebrow: "Growth Lever 02 / Channels",
  titleLead: "Growth across every",
  titleAccent: "channel that pays.",
  sub: "Owned, earned, paid, and real world, run as one engine. We test fast, cut what fails, and put budget behind what compounds.",
  tone: "dark" as const,
  accent: "teal" as const,
  cards: [
    {
      number: "01",
      title: "Organic & Community",
      desc: "The compounding channels most agencies skip. Community, local, and partnerships that build an audience before you spend on media.",
      tags: ["Growth Hacking", "Community", "Local", "Partnerships"],
    },
    {
      number: "02",
      title: "Email & Lifecycle",
      desc: "The channel you own. Lists and flows that turn one time buyers into repeat orders.",
      tags: ["List Building", "Flows", "Campaigns", "Retention"],
    },
    {
      number: "03",
      title: "Experiential & Activations",
      desc: "Launches, pop ups, and field activations engineered to capture content, grow the list, and feed the paid loop.",
      tags: ["Activations", "Launches", "Pop Ups", "Content Capture"],
    },
    {
      number: "04",
      title: "Paid Media",
      desc: "Google Ads and paid social, planned and managed for our clients. We run the tests and put spend where the return is.",
      tags: ["Google Ads", "Paid Social", "Creative Testing", "ROAS"],
    },
  ],
};

const software = {
  id: "software",
  eyebrow: "Growth Lever 03 / Digital Experience",
  titleLead: "Where browsers",
  titleAccent: "become buyers.",
  sub: "The websites, apps, and funnels where your growth converts. Senior engineers build them, then keep optimizing until the numbers move.",
  tone: "light" as const,
  accent: "purple" as const,
  cards: [
    {
      number: "01",
      title: "Websites & Ecommerce",
      desc: "Marketing sites and online stores built to convert. Fast, on brand, and measured.",
      tags: ["Marketing Sites", "Online Stores", "SEO", "Performance"],
    },
    {
      number: "02",
      title: "Web Apps",
      desc: "Ordering, booking, loyalty, and member portals. Full applications, front to back, engineered to scale.",
      tags: ["Frontend", "Backend", "Dashboards", "Integrations"],
    },
    {
      number: "03",
      title: "Mobile Apps",
      desc: "Native iOS and Android, or cross platform when it fits. From first build to the app store.",
      tags: ["iOS", "Android", "Cross Platform", "App Store"],
    },
    {
      number: "04",
      title: "Experience Optimization",
      desc: "Onboarding, funnels, and checkout, improved release by release. We find where customers drop off and fix it.",
      tags: ["Onboarding", "Funnels", "CRO", "A/B Testing"],
    },
  ],
};
---

<BaseLayout>
  <Nav />

  <main>
    <Hero />
    <Industries />
    <CookieSide />
    <OfferingCreative {...creative} />
    <OfferingGrowth {...growth} />
    <OfferingSoftware {...software} />
    <SelectedWork />
    <CollisionScene />
    <About />
    <CTA />
  </main>

  <Footer />
</BaseLayout>
