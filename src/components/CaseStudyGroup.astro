---
import CaseStudyCard from "./CaseStudyCard.astro";
import {
  serviceAreaLabels,
  type CaseStudy,
  type ServiceArea,
} from "../data/caseStudies";

interface Props {
  area: ServiceArea;
  studies: CaseStudy[];
  number: string;
}

const { area, studies, number } = Astro.props;
const label = serviceAreaLabels[area];
const headingId = `work-group-${area}`;
---

<section
  class:list={["work-group", `work-group--${area}`]}
  aria-labelledby={headingId}
  data-work-group
>
  <header class="work-group__header">
    <p class="work-group__index">{number} / Proof</p>
    <div class="work-group__heading">
      <h3 id={headingId}>{label}</h3>
      <p>
        {studies.length} {studies.length === 1 ? "story" : "stories"}
      </p>
    </div>
  </header>

  <div class="work-group__stories">
    {studies.map((study, index) => <CaseStudyCard study={study} index={index} />)}
  </div>
</section>

<style>
  .work-group {
    --group-accent: var(--color-teal-deep);
    display: grid;
    grid-template-columns: minmax(8rem, 0.22fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }

  .work-group--creative {
    --group-accent: var(--color-purple-deep);
  }

  .work-group--software {
    --group-accent: var(--color-purple);
  }

  .work-group + .work-group {
    margin-top: clamp(4rem, 9vw, 8rem);
    padding-top: clamp(4rem, 9vw, 8rem);
    border-top: 1px solid color-mix(in srgb, var(--color-navy) 12%, transparent);
  }

  .work-group__header {
    position: sticky;
    top: var(--scroll-offset);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 0.35rem;
  }

  .work-group__index {
    margin: 0;
    color: var(--group-accent);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .work-group__heading {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .work-group__heading h3 {
    margin: 0;
    color: var(--color-ink);
    font-size: clamp(1.35rem, 2.2vw, 2rem);
    letter-spacing: -0.02em;
  }

  .work-group__heading p {
    margin: 0;
    color: var(--color-ink-muted);
    font-size: 0.78rem;
  }

  .work-group__stories {
    display: grid;
    gap: clamp(1.25rem, 3vw, 2.5rem);
    min-width: 0;
  }

  @media (max-width: 900px) {
    .work-group {
      grid-template-columns: minmax(0, 1fr);
    }

    .work-group__header {
      position: static;
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: end;
    }

    .work-group__heading {
      align-items: flex-end;
      text-align: right;
    }
  }
</style>
