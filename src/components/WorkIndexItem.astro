---
import {
  getCaseStudyHref,
  serviceAreaLabels,
  type CaseStudy,
} from "../data/caseStudies";

interface Props {
  study: CaseStudy;
  /** compact = home preview rows; full = immersive /work/ index */
  variant?: "compact" | "full";
  index?: number;
}

const { study, variant = "full", index = 0 } = Astro.props;
const href = getCaseStudyHref(study);
const primary = study.metrics[0];
const areaLabel = serviceAreaLabels[study.serviceArea];
const number = String(index + 1).padStart(2, "0");
---

<article
  class:list={["work-item", `work-item--${variant}`]}
  data-work-item
  style={`--work-item-i: ${index};`}
>
  <a
    href={href}
    class="work-item__link"
    data-cursor="link"
    aria-label={`Read case study: ${study.title}`}
  >
    <span class="work-item__index" aria-hidden="true">{number}</span>

    <div class="work-item__main">
      <p class="work-item__meta">
        <span>{areaLabel}</span>
        <span aria-hidden="true">·</span>
        <span>{study.industry}</span>
        <span aria-hidden="true">·</span>
        <span>{study.year}</span>
      </p>
      <h3 class="work-item__title">{study.title}</h3>
      {
        variant === "full" && (
          <p class="work-item__summary">{study.catalogSummary}</p>
        )
      }
    </div>

    {
      primary && (
        <div class="work-item__metric">
          <span class="work-item__metric-value">{primary.value}</span>
          <span class="work-item__metric-label">{primary.label}</span>
        </div>
      )
    }

    <span class="work-item__arrow" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 18 18" fill="none">
        <path d="M4 9h10M10 5l4 4-4 4" />
      </svg>
    </span>
  </a>
</article>

<style>
  .work-item {
    --work-item-accent: var(--color-teal);
  }

  .work-item:nth-child(even) {
    --work-item-accent: var(--color-purple-deep);
  }

  .work-item__link {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto auto;
    gap: clamp(1rem, 3vw, 2.5rem);
    align-items: center;
    padding-block: clamp(1.35rem, 3vw, 2.25rem);
    color: inherit;
    text-decoration: none;
    border-top: 1px solid color-mix(in srgb, var(--color-navy) 12%, transparent);
    transition:
      background-color var(--duration-fast) var(--ease-out-soft),
      padding-inline var(--duration-base) var(--ease-out-soft);
  }

  .work-item:last-child .work-item__link {
    border-bottom: 1px solid color-mix(in srgb, var(--color-navy) 12%, transparent);
  }

  .work-item__link:hover,
  .work-item__link:focus-visible {
    background: color-mix(in srgb, var(--color-navy) 4%, transparent);
    padding-inline: clamp(0.75rem, 2vw, 1.25rem);
  }

  .work-item__index {
    color: color-mix(in srgb, var(--color-navy) 28%, transparent);
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .work-item__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0 0 0.55rem;
    color: var(--color-ink-muted);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .work-item__meta span:first-child {
    color: var(--work-item-accent);
  }

  .work-item__title {
    margin: 0;
    max-width: 18ch;
    font-size: clamp(1.55rem, 3.4vw, 3.1rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.02;
    transition: color var(--duration-fast) var(--ease-out-soft);
  }

  .work-item__link:hover .work-item__title,
  .work-item__link:focus-visible .work-item__title {
    color: var(--work-item-accent);
  }

  .work-item__summary {
    display: none;
    max-width: 40rem;
    margin: 0.85rem 0 0;
    color: var(--color-ink-muted);
    font-size: clamp(0.95rem, 1.2vw, 1.05rem);
    line-height: 1.55;
    text-wrap: pretty;
  }

  .work-item--full .work-item__summary {
    display: block;
  }

  .work-item__metric {
    display: grid;
    gap: 0.25rem;
    min-width: 7.5rem;
    text-align: right;
  }

  .work-item__metric-value {
    color: var(--work-item-accent);
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 3.4rem);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 0.9;
  }

  .work-item__metric-label {
    color: var(--color-ink-muted);
    font-size: 0.72rem;
    line-height: 1.3;
    max-width: 11rem;
    justify-self: end;
  }

  .work-item__arrow {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    color: var(--color-navy);
    border: 1px solid color-mix(in srgb, var(--color-navy) 16%, transparent);
    border-radius: 999px;
    transition:
      background-color var(--duration-fast) var(--ease-out-soft),
      color var(--duration-fast) var(--ease-out-soft),
      transform var(--duration-fast) var(--ease-out-soft);
  }

  .work-item__arrow path {
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .work-item__link:hover .work-item__arrow,
  .work-item__link:focus-visible .work-item__arrow {
    color: var(--color-cream);
    background: var(--color-navy);
    transform: translateX(0.2rem);
  }

  .work-item--compact .work-item__title {
    font-size: clamp(1.35rem, 2.6vw, 2.2rem);
    max-width: 22ch;
  }

  .work-item--compact .work-item__metric-value {
    font-size: clamp(1.45rem, 2.8vw, 2.4rem);
  }

  .work-item--compact .work-item__link {
    padding-block: clamp(1.1rem, 2.4vw, 1.6rem);
  }

  @media (max-width: 760px) {
    .work-item__link {
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.85rem 1rem;
    }

    .work-item__metric {
      grid-column: 2;
      text-align: left;
      min-width: 0;
    }

    .work-item__metric-label {
      justify-self: start;
      max-width: none;
    }

    .work-item__arrow {
      grid-row: 1 / span 2;
      grid-column: 3;
      align-self: center;
    }

    .work-item__summary {
      display: none;
    }
  }
</style>
