---
/**
 * CookieSide — "Human Craft"
 * The Cookie half of the agency: brand, content, creative strategy, campaigns.
 * Light cream section for tonal rhythm; purple accents.
 * Cards are cursor-reactive (proximity glow via JS) and scroll-revealed.
 */

const services = [
  {
    number: "01",
    title: "Brand & Identity",
    desc: "Strategy, naming, visual identity, brand guidelines. The full system that makes you recognisable and impossible to ignore.",
    tags: ["Strategy", "Naming", "Visual Identity", "Guidelines"],
  },
  {
    number: "02",
    title: "Content & Creative",
    desc: "Copy that converts, visuals that stop the scroll, content calendars that hold the line. Human voice, AI amplified.",
    tags: ["Copywriting", "Campaign Creative", "Content Strategy", "Production"],
  },
  {
    number: "03",
    title: "Creative Direction",
    desc: "Point of view, visual language, creative concepts. The taste layer that makes AI outputs feel unmistakably yours.",
    tags: ["Concept", "Art Direction", "Visual Language", "Oversight"],
  },
  {
    number: "04",
    title: "Campaigns",
    desc: "Full creative campaigns. Concept to launch. Paid, organic, always on. Craft at every touchpoint, at the speed AI enables.",
    tags: ["Paid Creative", "Organic", "Launch", "Always-On"],
  },
];
---

<section
  id="cookie"
  class="cookie-side"
  data-cookie-side
  data-tone="light"
  aria-labelledby="cookie-title"
>
  <div class="cookie-side__header section-shell">
    <p class="eyebrow cookie-side__eyebrow">The Cookie</p>
    <h2 id="cookie-title" class="cookie-side__headline">
      Human<br /><span class="cookie-side__accent">Craft.</span>
    </h2>
    <p class="cookie-side__sub">
      Great creatives don't need AI to be great. But with it, they're
      unstoppable. Wider exploration, faster iteration, more time for the
      decisions that actually define a brand.
    </p>
  </div>

  <div class="cookie-side__grid section-shell">
    {services.map((s) => (
      <article class="cookie-card" data-cookie-card>
        <span class="cookie-card__num">{s.number}</span>
        <h3 class="cookie-card__title">{s.title}</h3>
        <p class="cookie-card__desc">{s.desc}</p>
        <ul class="cookie-card__tags" aria-label="Service tags">
          {s.tags.map((t) => <li class="cookie-card__tag">{t}</li>)}
        </ul>
        <span class="cookie-card__glow" aria-hidden="true"></span>
      </article>
    ))}
  </div>

  <!-- Purple accent blob -->
  <div class="cookie-side__bg" aria-hidden="true">
    <span class="cookie-side__blob"></span>
  </div>
</section>

<style>
  .cookie-side {
    position: relative;
    background-color: var(--color-cream);
    color: var(--color-ink);
    overflow: clip;
    isolation: isolate;
  }

  .cookie-side__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .cookie-side__blob {
    position: absolute;
    top: -20vmax;
    right: -20vmax;
    width: 55vmax;
    height: 55vmax;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-purple) 0%, transparent 60%);
    filter: blur(120px);
    opacity: 0.08;
  }

  .cookie-side__header {
    position: relative;
    z-index: 1;
    padding-bottom: 0;
    max-width: 52rem;
  }
  .cookie-side__eyebrow {
    color: var(--color-purple-deep);
  }
  .cookie-side__headline {
    font-size: var(--text-display-xl);
    line-height: var(--text-display-xl--line-height);
    letter-spacing: var(--text-display-xl--letter-spacing);
    color: var(--color-ink);
    margin-top: 0.5rem;
  }
  .cookie-side__accent {
    color: var(--color-purple);
  }
  .cookie-side__sub {
    max-width: 34rem;
    font-size: var(--text-lead);
    line-height: var(--text-lead--line-height);
    color: var(--color-ink-muted);
    margin-top: 1rem;
  }

  /* ---------- Card grid ---------- */
  .cookie-side__grid {
    position: relative;
    z-index: 1;
    padding-top: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: 1.25rem;
  }

  .cookie-card {
    position: relative;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    background: var(--color-cream-200);
    border: 1px solid color-mix(in srgb, var(--color-purple) 14%, transparent);
    border-radius: var(--radius-card);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    overflow: clip;
    transition:
      border-color var(--duration-base) var(--ease-out-soft),
      transform    var(--duration-base) var(--ease-out-soft);
    will-change: transform;
  }
  .cookie-card:hover {
    border-color: color-mix(in srgb, var(--color-purple) 45%, transparent);
    transform: translateY(-3px);
  }

  .cookie-card__glow {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      circle at var(--gx, 50%) var(--gy, 50%),
      color-mix(in srgb, var(--color-purple) 12%, transparent) 0%,
      transparent 65%
    );
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out-soft);
    pointer-events: none;
  }
  .cookie-card:hover .cookie-card__glow {
    opacity: 1;
  }

  .cookie-card__num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--color-purple);
  }
  .cookie-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.1;
    color: var(--color-ink);
  }
  .cookie-card__desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    flex: 1;
  }

  .cookie-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
    margin-top: auto;
  }
  .cookie-card__tag {
    padding: 0.2rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-purple-deep);
    background: color-mix(in srgb, var(--color-purple) 10%, transparent);
    border-radius: var(--radius-pill);
  }
</style>

<script>
  import { gsap } from "../lib/gsap";
  import { prefersReducedMotion, isCoarsePointer } from "../lib/motion";

  const root = document.querySelector<HTMLElement>("[data-cookie-side]");
  if (root) initCookieSide(root);

  function initCookieSide(root: HTMLElement) {
    const cards = Array.from(root.querySelectorAll<HTMLElement>("[data-cookie-card]"));

    // Scroll-reveal: stagger in on enter.
    gsap.from(cards, {
      opacity: 0,
      y: 40,
      stagger: 0.1,
      duration: 0.7,
      ease: "power2.out",
      scrollTrigger: {
        trigger: root.querySelector(".cookie-side__grid"),
        start: "top 78%",
        once: true,
      },
    });

    if (prefersReducedMotion() || isCoarsePointer()) return;

    // Cursor-proximity glow via CSS custom properties.
    cards.forEach((card) => {
      card.addEventListener("pointermove", (e: PointerEvent) => {
        const r = card.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width) * 100;
        const y = ((e.clientY - r.top) / r.height) * 100;
        card.style.setProperty("--gx", `${x}%`);
        card.style.setProperty("--gy", `${y}%`);
      });
    });
  }
</script>
