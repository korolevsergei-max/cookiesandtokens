---
/**
 * CookieSide — "What We Do" (the umbrella declaration)
 * Three growth levers, one engine: Creative, Growth Channels, Digital Experience.
 * Light cream section for tonal rhythm; purple accents.
 * Cards are cursor-reactive (proximity glow via JS) and scroll-revealed.
 */

// Signposts to the three full lever sections below.
const services = [
  {
    number: "01",
    title: "Creative",
    desc: "A brand that does some of the selling. Positioning, identity, and content built to convert.",
    tags: ["Brand", "Identity", "Content", "Positioning"],
    href: "#creative",
  },
  {
    number: "02",
    title: "Growth Channels",
    desc: "Owned, earned, paid, and real world, run as one engine. Budget goes where the return is.",
    tags: ["Paid Media", "Lifecycle", "Experiential", "Organic"],
    href: "#growth",
  },
  {
    number: "03",
    title: "Digital Experience",
    desc: "Websites, apps, and funnels where browsers become buyers. Built, then optimized.",
    tags: ["Websites", "Web Apps", "Mobile", "CRO"],
    href: "#software",
  },
];
---

<section
  id="craft"
  class="craft-side"
  data-craft-side
  data-tone="light"
  aria-labelledby="craft-title"
>
  <div class="craft-side__header section-shell">
    <p class="eyebrow craft-side__eyebrow">What We Do</p>
    <h2 id="craft-title" class="craft-side__headline">
      Three levers.<br /><span class="craft-side__accent">One engine.</span>
    </h2>
    <p class="craft-side__sub">
      Brand, channels, and the digital experience where customers buy. Not
      three services. Three levers on the same number, pulled by one senior
      team.
    </p>
  </div>

  <div class="craft-side__grid section-shell">
    {services.map((s) => (
      <a class="craft-card" data-craft-card href={s.href} data-cursor="link">
        <span class="craft-card__num">{s.number}</span>
        <h3 class="craft-card__title">{s.title}</h3>
        <p class="craft-card__desc">{s.desc}</p>
        <ul class="craft-card__tags" aria-label="Service tags">
          {s.tags.map((t) => <li class="craft-card__tag">{t}</li>)}
        </ul>
        <span class="craft-card__more" aria-hidden="true">
          Explore
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="craft-card__glow" aria-hidden="true"></span>
      </a>
    ))}
  </div>

  <!-- Purple accent blob -->
  <div class="craft-side__bg" aria-hidden="true">
    <span class="craft-side__blob"></span>
  </div>
</section>

<style>
  .craft-side {
    position: relative;
    background-color: var(--color-cream-200);
    color: var(--color-ink);
    overflow: clip;
    isolation: isolate;
  }

  .craft-side__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .craft-side__blob {
    position: absolute;
    top: -20vmax;
    right: -20vmax;
    width: 55vmax;
    height: 55vmax;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-purple) 0%, transparent 60%);
    filter: blur(120px);
    opacity: 0.08;
  }

  .craft-side__header {
    position: relative;
    z-index: 1;
    padding-bottom: 0;
    max-width: 52rem;
  }
  .craft-side__eyebrow {
    color: var(--color-purple-deep);
  }
  .craft-side__headline {
    font-size: var(--text-display-xl);
    line-height: var(--text-display-xl--line-height);
    letter-spacing: var(--text-display-xl--letter-spacing);
    color: var(--color-ink);
    margin-top: 0.5rem;
  }
  .craft-side__accent {
    color: var(--color-purple);
  }
  .craft-side__sub {
    max-width: 34rem;
    font-size: var(--text-lead);
    line-height: var(--text-lead--line-height);
    color: var(--color-ink-muted);
    margin-top: 1rem;
  }

  /* ---------- Card grid ---------- */
  .craft-side__grid {
    position: relative;
    z-index: 1;
    padding-top: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: 1.25rem;
  }

  .craft-card {
    position: relative;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    background: var(--color-cream);
    border: 1px solid color-mix(in srgb, var(--color-purple) 14%, transparent);
    border-radius: var(--radius-card);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    overflow: clip;
    text-decoration: none;
    color: inherit;
    transition:
      border-color var(--duration-base) var(--ease-out-soft),
      transform    var(--duration-base) var(--ease-out-soft);
    will-change: transform;
  }
  .craft-card:hover {
    border-color: color-mix(in srgb, var(--color-purple) 45%, transparent);
    transform: translateY(-3px);
  }

  .craft-card__more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    /* Pin the link to the bottom of every card so it lands at the same
       height regardless of how long the description or tag row runs. */
    margin-top: auto;
    padding-top: 1rem;
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-purple-deep);
  }
  .craft-card__more svg {
    transition: transform var(--duration-base) var(--ease-out-soft);
  }
  .craft-card:hover .craft-card__more svg {
    transform: translateX(3px);
  }

  .craft-card__glow {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      circle at var(--gx, 50%) var(--gy, 50%),
      color-mix(in srgb, var(--color-purple) 12%, transparent) 0%,
      transparent 65%
    );
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out-soft);
    pointer-events: none;
  }
  .craft-card:hover .craft-card__glow {
    opacity: 1;
  }

  .craft-card__num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--color-purple);
  }
  .craft-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.1;
    color: var(--color-ink);
  }
  .craft-card__desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
  }

  .craft-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .craft-card__tag {
    padding: 0.2rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-purple-deep);
    background: color-mix(in srgb, var(--color-purple) 10%, transparent);
    border-radius: var(--radius-pill);
  }
</style>

<script>
  import { reveal } from "../lib/reveal";
  import { prefersReducedMotion, isCoarsePointer } from "../lib/motion";
  import { scrollTo } from "../lib/lenis";

  const root = document.querySelector<HTMLElement>("[data-craft-side]");
  if (root) initCookieSide(root);

  function initCookieSide(root: HTMLElement) {
    const cards = Array.from(root.querySelectorAll<HTMLElement>("[data-craft-card]"));

    // Scroll-reveal: stagger in on enter (shared page recipe).
    reveal(cards, { trigger: root.querySelector(".craft-side__grid") });

    // Signpost cards smooth-scroll to their offering section (same recipe as Nav).
    cards.forEach((card) => {
      card.addEventListener("click", (e) => {
        const target = card.getAttribute("href");
        if (target?.startsWith("#")) {
          e.preventDefault();
          scrollTo(target);
        }
      });
    });

    if (prefersReducedMotion() || isCoarsePointer()) return;

    // Cursor-proximity glow via CSS custom properties.
    cards.forEach((card) => {
      card.addEventListener("pointermove", (e: PointerEvent) => {
        const r = card.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width) * 100;
        const y = ((e.clientY - r.top) / r.height) * 100;
        card.style.setProperty("--gx", `${x}%`);
        card.style.setProperty("--gy", `${y}%`);
      });
    });
  }
</script>
