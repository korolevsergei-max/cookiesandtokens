---
/**
 * CookieSide — "What We Do"
 * The three offerings: Creative, Growth & Digital Marketing, Software.
 * Light cream section for tonal rhythm; purple accents.
 * Cards are cursor-reactive (proximity glow via JS) and scroll-revealed.
 */

// Signposts to the three full offering sections below.
const services = [
  {
    number: "01",
    title: "Creative",
    desc: "Brand, identity, content, and the strategy behind it. A real point of view, produced at volume.",
    tags: ["Brand", "Identity", "Content", "Creative Strategy"],
    href: "#creative",
  },
  {
    number: "02",
    title: "Growth & Marketing",
    desc: "Owned, earned, paid, and real world channels run as one engine. We test fast and put budget where the return is.",
    tags: ["Paid Media", "Lifecycle", "Experiential", "Activations"],
    href: "#growth",
  },
  {
    number: "03",
    title: "Software",
    desc: "Web and mobile apps, custom tools, and AI agents that run your workflows. Production software that ships.",
    tags: ["Web Apps", "iOS & Android", "Custom SaaS", "AI Agents"],
    href: "#software",
  },
];
---

<section
  id="cookie"
  class="cookie-side"
  data-cookie-side
  data-tone="light"
  aria-labelledby="cookie-title"
>
  <div class="cookie-side__header section-shell">
    <p class="eyebrow cookie-side__eyebrow">What We Do</p>
    <h2 id="cookie-title" class="cookie-side__headline">
      Three capabilities.<br /><span class="cookie-side__accent">One team.</span>
    </h2>
    <p class="cookie-side__sub">
      Brand, growth, and software, built by one team instead of three vendors.
      Every handoff between agencies loses time and intent. We remove the
      handoffs, so the brand sharpens the growth and the growth shapes the
      product, all from the same room.
    </p>
  </div>

  <div class="cookie-side__grid section-shell">
    {services.map((s) => (
      <a class="cookie-card" data-cookie-card href={s.href} data-cursor="link">
        <span class="cookie-card__num">{s.number}</span>
        <h3 class="cookie-card__title">{s.title}</h3>
        <p class="cookie-card__desc">{s.desc}</p>
        <ul class="cookie-card__tags" aria-label="Service tags">
          {s.tags.map((t) => <li class="cookie-card__tag">{t}</li>)}
        </ul>
        <span class="cookie-card__more" aria-hidden="true">
          Explore
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="cookie-card__glow" aria-hidden="true"></span>
      </a>
    ))}
  </div>

  <!-- Purple accent blob -->
  <div class="cookie-side__bg" aria-hidden="true">
    <span class="cookie-side__blob"></span>
  </div>
</section>

<style>
  .cookie-side {
    position: relative;
    background-color: var(--color-cream);
    color: var(--color-ink);
    overflow: clip;
    isolation: isolate;
  }

  .cookie-side__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .cookie-side__blob {
    position: absolute;
    top: -20vmax;
    right: -20vmax;
    width: 55vmax;
    height: 55vmax;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-purple) 0%, transparent 60%);
    filter: blur(120px);
    opacity: 0.08;
  }

  .cookie-side__header {
    position: relative;
    z-index: 1;
    padding-bottom: 0;
    max-width: 52rem;
  }
  .cookie-side__eyebrow {
    color: var(--color-purple-deep);
  }
  .cookie-side__headline {
    font-size: var(--text-display-xl);
    line-height: var(--text-display-xl--line-height);
    letter-spacing: var(--text-display-xl--letter-spacing);
    color: var(--color-ink);
    margin-top: 0.5rem;
  }
  .cookie-side__accent {
    color: var(--color-purple);
  }
  .cookie-side__sub {
    max-width: 34rem;
    font-size: var(--text-lead);
    line-height: var(--text-lead--line-height);
    color: var(--color-ink-muted);
    margin-top: 1rem;
  }

  /* ---------- Card grid ---------- */
  .cookie-side__grid {
    position: relative;
    z-index: 1;
    padding-top: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: 1.25rem;
  }

  .cookie-card {
    position: relative;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    background: var(--color-cream-200);
    border: 1px solid color-mix(in srgb, var(--color-purple) 14%, transparent);
    border-radius: var(--radius-card);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    overflow: clip;
    text-decoration: none;
    color: inherit;
    transition:
      border-color var(--duration-base) var(--ease-out-soft),
      transform    var(--duration-base) var(--ease-out-soft);
    will-change: transform;
  }
  .cookie-card:hover {
    border-color: color-mix(in srgb, var(--color-purple) 45%, transparent);
    transform: translateY(-3px);
  }

  .cookie-card__more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-purple-deep);
  }
  .cookie-card__more svg {
    transition: transform var(--duration-base) var(--ease-out-soft);
  }
  .cookie-card:hover .cookie-card__more svg {
    transform: translateX(3px);
  }

  .cookie-card__glow {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      circle at var(--gx, 50%) var(--gy, 50%),
      color-mix(in srgb, var(--color-purple) 12%, transparent) 0%,
      transparent 65%
    );
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out-soft);
    pointer-events: none;
  }
  .cookie-card:hover .cookie-card__glow {
    opacity: 1;
  }

  .cookie-card__num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--color-purple);
  }
  .cookie-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.1;
    color: var(--color-ink);
  }
  .cookie-card__desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    flex: 1;
  }

  .cookie-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
    margin-top: auto;
  }
  .cookie-card__tag {
    padding: 0.2rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-purple-deep);
    background: color-mix(in srgb, var(--color-purple) 10%, transparent);
    border-radius: var(--radius-pill);
  }
</style>

<script>
  import { reveal } from "../lib/reveal";
  import { prefersReducedMotion, isCoarsePointer } from "../lib/motion";
  import { scrollTo } from "../lib/lenis";

  const root = document.querySelector<HTMLElement>("[data-cookie-side]");
  if (root) initCookieSide(root);

  function initCookieSide(root: HTMLElement) {
    const cards = Array.from(root.querySelectorAll<HTMLElement>("[data-cookie-card]"));

    // Scroll-reveal: stagger in on enter (shared page recipe).
    reveal(cards, { trigger: root.querySelector(".cookie-side__grid") });

    // Signpost cards smooth-scroll to their offering section (same recipe as Nav).
    cards.forEach((card) => {
      card.addEventListener("click", (e) => {
        const target = card.getAttribute("href");
        if (target?.startsWith("#")) {
          e.preventDefault();
          scrollTo(target);
        }
      });
    });

    if (prefersReducedMotion() || isCoarsePointer()) return;

    // Cursor-proximity glow via CSS custom properties.
    cards.forEach((card) => {
      card.addEventListener("pointermove", (e: PointerEvent) => {
        const r = card.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width) * 100;
        const y = ((e.clientY - r.top) / r.height) * 100;
        card.style.setProperty("--gx", `${x}%`);
        card.style.setProperty("--gy", `${y}%`);
      });
    });
  }
</script>
