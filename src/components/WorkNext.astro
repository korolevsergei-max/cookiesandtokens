---
import {
  getCaseStudyHref,
  serviceAreaLabels,
  type CaseStudy,
} from "../data/caseStudies";

interface Props {
  next: CaseStudy;
}

const { next } = Astro.props;
const href = getCaseStudyHref(next);
const primary = next.metrics[0];
const areaLabel = serviceAreaLabels[next.serviceArea];
---

<section class="work-next" data-work-next aria-labelledby="work-next-title">
  <a href={href} class="work-next__link" data-cursor="link">
    <div class="work-next__inner">
      <p class="work-next__eyebrow">Next story</p>
      <div class="work-next__body">
        <div class="work-next__copy">
          <p class="work-next__meta">
            {areaLabel} · {next.industry} · {next.year}
          </p>
          <h2 id="work-next-title">{next.title}</h2>
        </div>
        {
          primary && (
            <div class="work-next__metric">
              <span class="work-next__metric-value">{primary.value}</span>
              <span class="work-next__metric-label">{primary.label}</span>
            </div>
          )
        }
      </div>
      <span class="work-next__cta">
        Continue
        <svg width="20" height="20" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M4 9h10M10 5l4 4-4 4" />
        </svg>
      </span>
    </div>
  </a>
</section>

<style>
  .work-next {
    color: var(--color-cream);
    background: var(--color-navy);
  }

  .work-next__link {
    display: block;
    padding-inline: var(--spacing-gutter);
    padding-block: clamp(4.5rem, 12vh, 9rem);
    color: inherit;
    text-decoration: none;
    background:
      radial-gradient(
        circle at 88% 30%,
        color-mix(in srgb, var(--color-teal) 18%, transparent),
        transparent 28rem
      ),
      radial-gradient(
        circle at 8% 80%,
        color-mix(in srgb, var(--color-purple) 16%, transparent),
        transparent 24rem
      ),
      var(--color-navy);
    border-top: 1px solid color-mix(in srgb, var(--color-cream) 10%, transparent);
    transition: background-color var(--duration-base) var(--ease-out-soft);
  }

  .work-next__link:hover,
  .work-next__link:focus-visible {
    background:
      radial-gradient(
        circle at 88% 30%,
        color-mix(in srgb, var(--color-teal) 26%, transparent),
        transparent 28rem
      ),
      radial-gradient(
        circle at 8% 80%,
        color-mix(in srgb, var(--color-purple) 22%, transparent),
        transparent 24rem
      ),
      color-mix(in srgb, var(--color-navy) 92%, var(--color-teal));
  }

  .work-next__inner {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
    max-width: 88rem;
    margin-inline: auto;
  }

  .work-next__eyebrow {
    margin: 0;
    color: var(--color-teal);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .work-next__body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: end;
  }

  .work-next__meta {
    margin: 0 0 0.85rem;
    color: color-mix(in srgb, var(--color-cream) 55%, transparent);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .work-next__copy h2 {
    max-width: 14ch;
    margin: 0;
    font-size: clamp(2.6rem, 7vw, 6.4rem);
    line-height: 0.94;
    letter-spacing: -0.05em;
  }

  .work-next__metric {
    display: grid;
    gap: 0.35rem;
    text-align: right;
    min-width: 8rem;
  }

  .work-next__metric-value {
    color: var(--color-teal);
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 4.6rem);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    letter-spacing: -0.05em;
    line-height: 0.88;
  }

  .work-next__metric-label {
    color: color-mix(in srgb, var(--color-cream) 55%, transparent);
    font-size: 0.8rem;
    line-height: 1.35;
    max-width: 12rem;
    justify-self: end;
  }

  .work-next__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    width: fit-content;
    color: var(--color-teal-bright);
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
  }

  .work-next__cta svg {
    transition: transform var(--duration-fast) var(--ease-out-soft);
  }

  .work-next__cta path {
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .work-next__link:hover .work-next__cta svg,
  .work-next__link:focus-visible .work-next__cta svg {
    transform: translateX(0.3rem);
  }

  @media (max-width: 700px) {
    .work-next__body {
      grid-template-columns: minmax(0, 1fr);
    }

    .work-next__metric {
      text-align: left;
    }

    .work-next__metric-label {
      justify-self: start;
      max-width: none;
    }
  }
</style>
