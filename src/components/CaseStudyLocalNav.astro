---
import type { CaseStudy } from "../data/caseStudies";

interface Props {
  study: CaseStudy;
}

const { study } = Astro.props;
---

<nav class="story-local-nav" aria-label="Case study sections" data-story-local-nav>
  <div class="story-local-nav__inner">
    <span class="story-local-nav__label">Story</span>
    <div class="story-local-nav__links">
      {
        study.steps.map((step) => (
          <a href={`#${step.id}`} class="story-local-nav__link" data-story-nav-link={step.id} data-cursor="link">
            <span>{step.number}</span>
            {step.label}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<style>
  .story-local-nav {
    position: sticky;
    top: var(--nav-height);
    z-index: 90;
    color: var(--color-cream);
    background: color-mix(in srgb, var(--color-navy) 90%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-cream) 9%, transparent);
    backdrop-filter: blur(18px) saturate(1.25);
    -webkit-backdrop-filter: blur(18px) saturate(1.25);
  }

  .story-local-nav__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    max-width: 88rem;
    margin-inline: auto;
    padding: 0.65rem var(--spacing-gutter);
  }

  .story-local-nav__label {
    color: color-mix(in srgb, var(--color-cream) 48%, transparent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .story-local-nav__links {
    display: flex;
    gap: 0.35rem;
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .story-local-nav__links::-webkit-scrollbar {
    display: none;
  }

  .story-local-nav__link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 44px;
    padding: 0.55rem 0.85rem;
    color: color-mix(in srgb, var(--color-cream) 65%, transparent);
    border-radius: 0.8rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.055em;
    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;
    transition:
      color var(--duration-fast) var(--ease-out-soft),
      background-color var(--duration-fast) var(--ease-out-soft);
  }

  .story-local-nav__link span {
    color: var(--color-teal);
    font-variant-numeric: tabular-nums;
  }

  .story-local-nav__link:hover,
  .story-local-nav__link:focus-visible,
  .story-local-nav__link[aria-current="true"] {
    color: var(--color-navy);
    background: var(--color-teal);
  }

  .story-local-nav__link[aria-current="true"] span,
  .story-local-nav__link:hover span,
  .story-local-nav__link:focus-visible span {
    color: var(--color-navy);
  }

  @media (max-width: 640px) {
    .story-local-nav__inner {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.35rem;
      padding-block: 0.6rem;
    }

    .story-local-nav__links {
      width: calc(100% + var(--spacing-gutter));
      padding-right: var(--spacing-gutter);
    }
  }
</style>

<script>
  import { scrollTo } from "../lib/lenis";

  const nav = document.querySelector<HTMLElement>("[data-story-local-nav]");
  const sections = Array.from(document.querySelectorAll<HTMLElement>("[data-story-section]"));
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-story-nav-link]"));

  if (nav && sections.length && links.length) {
    const setActive = (id: string) => {
      links.forEach((link) => {
        const active = link.dataset.storyNavLink === id;
        if (active) {
          link.setAttribute("aria-current", "true");
          link.scrollIntoView({ block: "nearest", inline: "nearest" });
        } else {
          link.removeAttribute("aria-current");
        }
      });
    };

    links.forEach((link) => {
      link.addEventListener("click", (event) => {
        const target = link.getAttribute("href");
        if (!target) return;
        event.preventDefault();
        event.stopPropagation();
        scrollTo(target);
        history.pushState(null, "", target);
        setActive(target.slice(1));
      });
    });

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (visible?.target.id) {
          setActive(visible.target.id);
        }
      },
      {
        rootMargin: "-35% 0px -50% 0px",
        threshold: [0.2, 0.45, 0.7],
      }
    );

    sections.forEach((section) => observer.observe(section));
    setActive((location.hash || `#${sections[0].id}`).slice(1));
  }
</script>
