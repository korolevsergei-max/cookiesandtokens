---
/**
 * Process — "The Recipe"
 * Four steps revealed on scroll via staggered GSAP entrance.
 * Alternating accent colors (purple → teal → purple → teal) for visual rhythm.
 */

const steps = [
  {
    num: "01",
    accent: "purple",
    title: "Listen",
    body: "We start with outcomes, not deliverables. Where are your creative bottlenecks? Where is your operational drag? We audit your brand and your systems, map the gap, and define 'great' before a single brief is written.",
    tags: ["Brand Audit", "Ops Audit", "Outcome Mapping", "Brief Setting"],
  },
  {
    num: "02",
    accent: "teal",
    title: "Build the system",
    body: "We design the workflows, tools, and AI stack that power the work. Creative and operational, custom to your team, your voice, your constraints. Infrastructure first, so the work moves.",
    tags: ["Workflow Design", "AI Stack", "Ops Automation", "Integration"],
  },
  {
    num: "03",
    accent: "purple",
    title: "Amplify",
    body: "Elite creatives, amplified by AI at every step. Faster briefs. Wider exploration. Leaner operations. And real human oversight on everything that ships.",
    tags: ["Creative Production", "AI Amplification", "Quality Review"],
  },
  {
    num: "04",
    accent: "teal",
    title: "Scale",
    body: "Compound the advantage. More output, higher quality, tighter margins, with measurement in place to prove it and a system built to keep improving, campaign after campaign.",
    tags: ["Performance", "Reporting", "Iteration"],
  },
];
---

<section
  id="process"
  class="process section-shell"
  data-process
  data-tone="dark"
  aria-labelledby="process-title"
>
  <div class="process__header">
    <p class="eyebrow process__eyebrow">How We Work</p>
    <h2 id="process-title" class="process__headline">
      The&nbsp;<span class="text-gradient-overlap">Recipe.</span>
    </h2>
    <p class="process__sub">
      Four steps that compound. Each one makes the next one better.
    </p>
  </div>

  <ol class="process__steps" data-process-steps>
    {steps.map((s, i) => (
      <li class:list={["process__step", `process__step--${s.accent}`]} data-step={i}>
        <div class="process__step-num">
          <span class:list={["process__step-accent", `process__step-accent--${s.accent}`]}>
            {s.num}
          </span>
          {i < steps.length - 1 && (
            <span class="process__connector" aria-hidden="true"></span>
          )}
        </div>
        <div class="process__step-content">
          <h3 class="process__step-title">{s.title}</h3>
          <p class="process__step-body">{s.body}</p>
          <ul class="process__step-tags" aria-label="Step details">
            {s.tags.map((t) => (
              <li class:list={["process__tag", `process__tag--${s.accent}`]}>{t}</li>
            ))}
          </ul>
        </div>
      </li>
    ))}
  </ol>

  <div class="process__bg" aria-hidden="true">
    <span class="process__blob process__blob--purple"></span>
    <span class="process__blob process__blob--teal"></span>
  </div>
</section>

<style>
  .process {
    position: relative;
    background-color: var(--color-navy);
    color: var(--color-cream);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(3rem, 7vh, 5rem);
    overflow: clip;
    isolation: isolate;
  }

  .process__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .process__blob {
    position: absolute;
    width: 45vmax;
    height: 45vmax;
    border-radius: 50%;
    filter: blur(110px);
    opacity: 0.1;
  }
  .process__blob--purple {
    top: 5%; right: -15vmax;
    background: radial-gradient(circle, var(--color-purple) 0%, transparent 65%);
  }
  .process__blob--teal {
    bottom: 5%; left: -15vmax;
    background: radial-gradient(circle, var(--color-teal) 0%, transparent 65%);
  }

  .process__header {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .process__eyebrow {
    color: color-mix(in srgb, var(--color-cream) 42%, transparent);
  }
  .process__headline {
    font-size: var(--text-display-lg);
    line-height: var(--text-display-lg--line-height);
    letter-spacing: var(--text-display-lg--letter-spacing);
  }
  .process__sub {
    font-size: var(--text-lead);
    line-height: var(--text-lead--line-height);
    color: color-mix(in srgb, var(--color-cream) 60%, transparent);
    max-width: 30rem;
  }

  /* ---------- Steps ---------- */
  .process__steps {
    position: relative;
    z-index: 1;
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
    max-width: 52rem;
  }

  .process__step {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 0 clamp(1.25rem, 3vw, 2.5rem);
    padding-block: clamp(1.5rem, 3vh, 2.5rem);
    position: relative;
  }
  .process__step + .process__step {
    border-top: 1px solid color-mix(in srgb, var(--color-cream) 8%, transparent);
  }

  .process__step-num {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding-top: 0.2rem;
  }
  .process__step-accent {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    width: 2.75rem;
    height: 2.75rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .process__step-accent--purple {
    color: var(--color-purple);
    background: color-mix(in srgb, var(--color-purple) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-purple) 25%, transparent);
  }
  .process__step-accent--teal {
    color: var(--color-teal);
    background: color-mix(in srgb, var(--color-teal) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-teal) 22%, transparent);
  }

  /* Vertical connector line */
  .process__connector {
    flex: 1;
    width: 1px;
    min-height: 1.5rem;
    margin-top: 0.5rem;
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--color-cream) 12%, transparent),
      transparent
    );
  }

  .process__step-content {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .process__step-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .process__step-body {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-cream) 63%, transparent);
    max-width: 40rem;
  }

  .process__step-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
    margin-top: 0.25rem;
  }
  .process__tag {
    padding: 0.2rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: var(--radius-pill);
  }
  .process__tag--purple {
    color: var(--color-purple);
    background: color-mix(in srgb, var(--color-purple) 10%, transparent);
  }
  .process__tag--teal {
    color: var(--color-teal);
    background: color-mix(in srgb, var(--color-teal) 10%, transparent);
  }
</style>

<script>
  import { gsap, ease } from "../lib/gsap";
  import { reveal } from "../lib/reveal";
  import { prefersReducedMotion } from "../lib/motion";

  const root = document.querySelector<HTMLElement>("[data-process]");
  if (root) initProcess(root);

  function initProcess(root: HTMLElement) {
    if (prefersReducedMotion()) return;

    reveal(root.querySelector(".process__header"));

    // Steps keep their signature alternating slide-in, but on the shared
    // ease + trigger line so the rhythm matches the rest of the page.
    const steps = Array.from(root.querySelectorAll<HTMLElement>("[data-step]"));
    steps.forEach((step, i) => {
      gsap.from(step, {
        opacity: 0,
        x: i % 2 === 0 ? -32 : 32,
        duration: 0.8,
        ease: ease.reveal,
        scrollTrigger: { trigger: step, start: "top 80%", once: true },
      });
    });
  }
</script>
