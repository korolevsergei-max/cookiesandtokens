---
import { Image } from "astro:assets";
import type { CaseStudyStep } from "../data/caseStudies";

interface Props {
  step: CaseStudyStep;
}

const { step } = Astro.props;
const { visual } = step;
const image = visual.image;
---

<figure
  class:list={["story-visual", image && "story-visual--image"]}
  aria-label={image ? undefined : visual.alt}
  role={image ? undefined : "img"}
>
  {
    image ? (
      <Image
        src={image}
        alt={visual.alt}
        class="story-visual__image"
        widths={[480, 720, 960, 1200]}
        sizes="(max-width: 860px) 100vw, 46vw"
        format="webp"
        quality={86}
        loading="lazy"
      />
    ) : (
      <div class="story-visual__diagram" aria-hidden="true">
        <span class="story-visual__orbit story-visual__orbit--one"></span>
        <span class="story-visual__orbit story-visual__orbit--two"></span>
        <span class="story-visual__line story-visual__line--one"></span>
        <span class="story-visual__line story-visual__line--two"></span>
        <span class="story-visual__node story-visual__node--one"></span>
        <span class="story-visual__node story-visual__node--two"></span>
        <span class="story-visual__node story-visual__node--three"></span>
      </div>
    )
  }

  <figcaption class="story-visual__caption">
    <span class="story-visual__eyebrow">{visual.eyebrow}</span>
    <strong>{visual.title}</strong>
    <dl class="story-visual__stats">
      {
        visual.items.map((item) => (
          <div>
            <dt>{item.label}</dt>
            <dd>{item.value}</dd>
          </div>
        ))
      }
    </dl>
  </figcaption>
  <span class="story-visual__watermark" aria-hidden="true">{step.number}</span>
</figure>

<style>
  .story-visual {
    position: relative;
    overflow: hidden;
    min-height: clamp(25rem, 42vw, 38rem);
    margin: 0;
    color: var(--color-navy);
    background:
      radial-gradient(
        circle at 82% 12%,
        color-mix(in srgb, var(--color-teal) 26%, transparent),
        transparent 19rem
      ),
      radial-gradient(
        circle at 13% 90%,
        color-mix(in srgb, var(--color-purple) 20%, transparent),
        transparent 18rem
      ),
      var(--color-cream);
    border-radius: clamp(1.1rem, 2.2vw, 1.8rem);
    isolation: isolate;
  }

  .story-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border: 1px solid color-mix(in srgb, var(--color-navy) 12%, transparent);
    border-radius: inherit;
    z-index: 4;
  }

  .story-visual__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .story-visual--image::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-navy) 4%, transparent),
        color-mix(in srgb, var(--color-navy) 40%, transparent)
      );
    pointer-events: none;
  }

  .story-visual__diagram {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .story-visual__orbit,
  .story-visual__line,
  .story-visual__node {
    position: absolute;
    display: block;
  }

  .story-visual__orbit {
    border: 1px solid color-mix(in srgb, var(--color-navy) 13%, transparent);
    border-radius: 999px;
  }

  .story-visual__orbit--one {
    width: 58%;
    aspect-ratio: 1;
    left: 9%;
    top: 15%;
  }

  .story-visual__orbit--two {
    width: 43%;
    aspect-ratio: 1;
    right: 8%;
    bottom: 10%;
  }

  .story-visual__line {
    height: 2px;
    background: linear-gradient(
      90deg,
      var(--color-purple),
      var(--color-teal)
    );
    opacity: 0.55;
    transform-origin: left center;
  }

  .story-visual__line--one {
    width: 58%;
    left: 18%;
    top: 45%;
    transform: rotate(-13deg);
  }

  .story-visual__line--two {
    width: 46%;
    left: 31%;
    top: 58%;
    transform: rotate(17deg);
  }

  .story-visual__node {
    width: clamp(4.5rem, 10vw, 7rem);
    aspect-ratio: 1;
    background:
      radial-gradient(circle at 35% 30%, var(--color-cream), transparent 32%),
      var(--color-navy);
    border-radius: 1.35rem;
    box-shadow: 0 1.5rem 4rem color-mix(in srgb, var(--color-navy) 20%, transparent);
  }

  .story-visual__node--one {
    left: 13%;
    top: 22%;
  }

  .story-visual__node--two {
    right: 14%;
    top: 35%;
    background:
      radial-gradient(circle at 35% 30%, var(--color-cream), transparent 32%),
      var(--color-purple-deep);
  }

  .story-visual__node--three {
    left: 40%;
    bottom: 15%;
    background:
      radial-gradient(circle at 35% 30%, var(--color-cream), transparent 32%),
      var(--color-teal-deep);
  }

  .story-visual__caption {
    position: absolute;
    inset-inline: clamp(1rem, 3vw, 2rem);
    bottom: clamp(1rem, 3vw, 2rem);
    z-index: 3;
    display: grid;
    gap: 0.9rem;
    max-width: 32rem;
    padding: clamp(1rem, 2.2vw, 1.4rem);
    color: var(--color-cream);
    background: color-mix(in srgb, var(--color-navy) 88%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-cream) 12%, transparent);
    border-radius: 1.1rem;
    backdrop-filter: blur(18px) saturate(1.25);
    -webkit-backdrop-filter: blur(18px) saturate(1.25);
  }

  .story-visual__eyebrow {
    color: var(--color-teal);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .story-visual__caption strong {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.3vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .story-visual__stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(5.5rem, 1fr));
    gap: 0.7rem;
    margin: 0;
  }

  .story-visual__stats div {
    padding-top: 0.65rem;
    border-top: 1px solid color-mix(in srgb, var(--color-cream) 14%, transparent);
  }

  .story-visual__stats dt {
    color: color-mix(in srgb, var(--color-cream) 56%, transparent);
    font-size: 0.68rem;
    line-height: 1.25;
  }

  .story-visual__stats dd {
    margin: 0.25rem 0 0;
    color: var(--color-teal-bright);
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 3vw, 2.35rem);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 0.9;
  }

  .story-visual__watermark {
    position: absolute;
    right: -0.05em;
    top: -0.19em;
    z-index: 2;
    color: color-mix(in srgb, var(--color-navy) 8%, transparent);
    font: 700 clamp(8rem, 18vw, 16rem)/1 var(--font-display);
    letter-spacing: -0.08em;
    pointer-events: none;
  }

  @media (max-width: 560px) {
    .story-visual {
      min-height: 31rem;
    }

    .story-visual__stats {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
