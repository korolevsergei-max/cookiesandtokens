---
import { Image } from "astro:assets";
import type { CaseStudyStep } from "../data/caseStudies";

interface Props {
  step: CaseStudyStep;
}

const { step } = Astro.props;
const image = step.visual.image;
---

<figure
  class:list={[
    "story-visual",
    image && "story-visual--image",
    `story-visual--${step.id}`,
  ]}
  aria-label={image ? undefined : step.visual.alt}
  role={image ? undefined : "img"}
>
  {
    image ? (
      <Image
        src={image}
        alt={step.visual.alt}
        class="story-visual__image"
        widths={[480, 720, 960, 1200]}
        sizes="(max-width: 860px) 100vw, 46vw"
        format="webp"
        quality={86}
        loading="lazy"
      />
    ) : (
      <div class="story-visual__diagram" aria-hidden="true">
        <span class="story-visual__orbit story-visual__orbit--one"></span>
        <span class="story-visual__orbit story-visual__orbit--two"></span>
        <span class="story-visual__line story-visual__line--one"></span>
        <span class="story-visual__line story-visual__line--two"></span>
        <span class="story-visual__node story-visual__node--one"></span>
        <span class="story-visual__node story-visual__node--two"></span>
        <span class="story-visual__node story-visual__node--three"></span>
      </div>
    )
  }

  <figcaption class="story-visual__caption">
    <span class="story-visual__eyebrow">{step.visual.eyebrow}</span>
    <strong>{step.visual.title}</strong>
  </figcaption>
  <span class="story-visual__watermark" aria-hidden="true">{step.number}</span>
</figure>

<style>
  .story-visual {
    position: relative;
    overflow: hidden;
    min-height: clamp(22rem, 36vw, 32rem);
    margin: 0;
    color: var(--color-navy);
    background:
      radial-gradient(
        circle at 82% 12%,
        color-mix(in srgb, var(--color-teal) 26%, transparent),
        transparent 19rem
      ),
      radial-gradient(
        circle at 13% 90%,
        color-mix(in srgb, var(--color-purple) 20%, transparent),
        transparent 18rem
      ),
      var(--color-cream);
    border-radius: clamp(1.1rem, 2.2vw, 1.8rem);
    isolation: isolate;
  }

  .story-visual--approach {
    background:
      radial-gradient(
        circle at 20% 20%,
        color-mix(in srgb, var(--color-purple) 24%, transparent),
        transparent 18rem
      ),
      radial-gradient(
        circle at 85% 75%,
        color-mix(in srgb, var(--color-teal) 22%, transparent),
        transparent 16rem
      ),
      var(--color-cream);
  }

  .story-visual--outcome {
    background:
      radial-gradient(
        circle at 70% 30%,
        color-mix(in srgb, var(--color-teal) 30%, transparent),
        transparent 17rem
      ),
      radial-gradient(
        circle at 15% 80%,
        color-mix(in srgb, var(--color-purple) 16%, transparent),
        transparent 15rem
      ),
      var(--color-cream);
  }

  .story-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border: 1px solid color-mix(in srgb, var(--color-navy) 12%, transparent);
    border-radius: inherit;
    z-index: 4;
  }

  .story-visual__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .story-visual--image::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-navy) 0%, transparent) 35%,
      color-mix(in srgb, var(--color-navy) 28%, transparent) 72%,
      color-mix(in srgb, var(--color-navy) 55%, transparent)
    );
    pointer-events: none;
  }

  .story-visual__diagram {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .story-visual__orbit,
  .story-visual__line,
  .story-visual__node {
    position: absolute;
    display: block;
  }

  .story-visual__orbit {
    border: 1px solid color-mix(in srgb, var(--color-navy) 13%, transparent);
    border-radius: 999px;
  }

  .story-visual__orbit--one {
    width: 58%;
    aspect-ratio: 1;
    left: 9%;
    top: 15%;
  }

  .story-visual__orbit--two {
    width: 43%;
    aspect-ratio: 1;
    right: 8%;
    bottom: 10%;
  }

  .story-visual--approach .story-visual__orbit--one {
    width: 48%;
    left: 28%;
    top: 10%;
  }

  .story-visual--outcome .story-visual__orbit--two {
    width: 52%;
    right: 4%;
    bottom: 18%;
  }

  .story-visual__line {
    height: 2px;
    background: linear-gradient(90deg, var(--color-purple), var(--color-teal));
    opacity: 0.55;
    transform-origin: left center;
  }

  .story-visual__line--one {
    width: 58%;
    left: 18%;
    top: 45%;
    transform: rotate(-13deg);
  }

  .story-visual__line--two {
    width: 46%;
    left: 31%;
    top: 58%;
    transform: rotate(17deg);
  }

  .story-visual--approach .story-visual__line--one {
    transform: rotate(8deg);
    top: 40%;
  }

  .story-visual--outcome .story-visual__line--two {
    transform: rotate(-8deg);
    width: 52%;
  }

  .story-visual__node {
    width: clamp(4rem, 9vw, 6.2rem);
    aspect-ratio: 1;
    background:
      radial-gradient(circle at 35% 30%, var(--color-cream), transparent 32%),
      var(--color-navy);
    border-radius: 1.25rem;
    box-shadow: 0 1.5rem 4rem color-mix(in srgb, var(--color-navy) 20%, transparent);
  }

  .story-visual__node--one {
    left: 13%;
    top: 22%;
  }

  .story-visual__node--two {
    right: 14%;
    top: 35%;
    background:
      radial-gradient(circle at 35% 30%, var(--color-cream), transparent 32%),
      var(--color-purple-deep);
  }

  .story-visual__node--three {
    left: 40%;
    bottom: 15%;
    background:
      radial-gradient(circle at 35% 30%, var(--color-cream), transparent 32%),
      var(--color-teal-deep);
  }

  .story-visual--approach .story-visual__node--one {
    border-radius: 999px;
  }

  .story-visual--outcome .story-visual__node--three {
    left: 22%;
    bottom: 22%;
  }

  .story-visual__caption {
    position: absolute;
    inset-inline: clamp(1rem, 3vw, 2rem);
    bottom: clamp(1rem, 3vw, 2rem);
    z-index: 3;
    display: grid;
    gap: 0.4rem;
    max-width: 28rem;
    padding: clamp(0.95rem, 2vw, 1.25rem);
    color: var(--color-cream);
    background: color-mix(in srgb, var(--color-navy) 88%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-cream) 12%, transparent);
    border-radius: 1rem;
    backdrop-filter: blur(18px) saturate(1.25);
    -webkit-backdrop-filter: blur(18px) saturate(1.25);
  }

  .story-visual__eyebrow {
    color: var(--color-teal);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .story-visual__caption strong {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.2vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .story-visual__watermark {
    position: absolute;
    right: -0.05em;
    top: -0.19em;
    z-index: 2;
    color: color-mix(in srgb, var(--color-navy) 8%, transparent);
    font: 700 clamp(7rem, 16vw, 14rem)/1 var(--font-display);
    letter-spacing: -0.08em;
    pointer-events: none;
  }

  @media (max-width: 560px) {
    .story-visual {
      min-height: 26rem;
    }
  }
</style>
