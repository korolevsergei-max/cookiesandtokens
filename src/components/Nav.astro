---
/**
 * Nav — sticky mini-nav that appears once the hero scrolls out of view on the
 * homepage, and stays available on nested routes. Includes an accessible mobile
 * drawer with every primary destination.
 */
import logoMarkRaw from "../assets/logo-mark.svg?raw";
import { primaryNavLinks, resolveNavHref } from "../data/siteNav";

const pathname = Astro.url.pathname;
const links = primaryNavLinks.map((link) => ({
  label: link.label,
  href: resolveNavHref(link, pathname),
  isActive:
    (link.href === "/work/" && pathname.startsWith("/work")) ||
    (link.homeHref === "#work" && pathname.startsWith("/work")),
}));
const isHome = pathname === "/" || pathname === "";
---

<header
  class:list={["site-nav", !isHome && "is-visible", !isHome && "is-static"]}
  data-nav
  data-nav-home={isHome ? "true" : "false"}
  aria-label="Site navigation"
>
  <div class="site-nav__inner">
    <a href="/" class="site-nav__logo" data-cursor="link" aria-label="Cookies and Tokens home">
      <span class="site-nav__mark" set:html={logoMarkRaw} />
      <span class="site-nav__wordmark">Cookies&nbsp;&amp;&nbsp;Tokens</span>
    </a>

    <nav class="site-nav__links" aria-label="Primary">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={["site-nav__link", l.isActive && "is-active"]}
            data-cursor="link"
            aria-current={l.isActive ? "page" : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <a href={isHome ? "#cta" : "/#cta"} class="site-nav__cta" data-cursor="link">
      Work with us
    </a>

    <button
      type="button"
      class="site-nav__menu-btn"
      data-nav-menu-btn
      data-cursor="link"
      aria-expanded="false"
      aria-controls="site-nav-drawer"
    >
      <span class="site-nav__menu-label" data-nav-menu-label>Menu</span>
      <span class="site-nav__menu-bars" aria-hidden="true">
        <span></span>
        <span></span>
      </span>
    </button>
  </div>

  <div
    id="site-nav-drawer"
    class="site-nav__drawer"
    data-nav-drawer
    hidden
  >
    <nav class="site-nav__drawer-nav" aria-label="Mobile">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={["site-nav__drawer-link", l.isActive && "is-active"]}
            data-cursor="link"
            aria-current={l.isActive ? "page" : undefined}
          >
            {l.label}
          </a>
        ))
      }
      <a href={isHome ? "#cta" : "/#cta"} class="site-nav__drawer-cta" data-cursor="link">
        Work with us
      </a>
    </nav>
  </div>
</header>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    inset-inline: 0;
    z-index: 1000;
    transform: translateY(-100%);
    opacity: 0;
    will-change: transform, opacity;
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .site-nav.is-visible,
  .site-nav.is-static {
    transform: translateY(0);
    opacity: 1;
  }

  .site-nav.is-static {
    will-change: auto;
  }

  .site-nav__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-inline: var(--spacing-gutter);
    padding-block: 0.75rem;
    background: color-mix(in srgb, var(--color-navy) 88%, transparent);
    backdrop-filter: blur(18px) saturate(1.4);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
    border-bottom: 1px solid color-mix(in srgb, var(--color-cream) 8%, transparent);
  }

  .site-nav__logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--color-cream);
    flex-shrink: 0;
  }
  .site-nav__mark {
    width: 36px;
    height: auto;
    display: block;
    flex-shrink: 0;
  }
  .site-nav__mark :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }
  .site-nav__wordmark {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .site-nav__links {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    margin-inline: auto;
    flex-wrap: wrap;
  }
  .site-nav__link {
    padding: 0.35rem 0.65rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: color-mix(in srgb, var(--color-cream) 65%, transparent);
    text-decoration: none;
    border-radius: var(--radius-pill);
    transition:
      color var(--duration-fast) var(--ease-out-soft),
      background var(--duration-fast) var(--ease-out-soft);
  }
  .site-nav__link:hover,
  .site-nav__link.is-active {
    color: var(--color-cream);
    background: color-mix(in srgb, var(--color-cream) 8%, transparent);
  }

  .site-nav__cta {
    flex-shrink: 0;
    padding: 0.45rem 1.1rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--color-navy);
    background: var(--color-teal);
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition:
      background var(--duration-fast) var(--ease-out-soft),
      transform var(--duration-fast) var(--ease-out-soft);
    white-space: nowrap;
  }
  .site-nav__cta:hover {
    background: var(--color-teal-bright);
    transform: scale(1.03);
  }

  .site-nav__menu-btn {
    display: none;
    align-items: center;
    gap: 0.55rem;
    min-height: 44px;
    padding: 0.35rem 0.75rem;
    color: var(--color-cream);
    background: color-mix(in srgb, var(--color-cream) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-cream) 12%, transparent);
    border-radius: var(--radius-pill);
    font: 600 0.78rem/1 var(--font-body);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .site-nav__menu-bars {
    display: grid;
    gap: 0.28rem;
    width: 1rem;
  }

  .site-nav__menu-bars span {
    display: block;
    height: 1.5px;
    background: currentColor;
    transition: transform var(--duration-fast) var(--ease-out-soft);
  }

  .site-nav[data-menu-open] .site-nav__menu-bars span:first-child {
    transform: translateY(2.5px) rotate(45deg);
  }

  .site-nav[data-menu-open] .site-nav__menu-bars span:last-child {
    transform: translateY(-2.5px) rotate(-45deg);
  }

  .site-nav__drawer {
    padding: 0.75rem var(--spacing-gutter) 1.25rem;
    background: color-mix(in srgb, var(--color-navy) 96%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-cream) 8%, transparent);
  }

  .site-nav__drawer[hidden] {
    display: none;
  }

  .site-nav__drawer-nav {
    display: grid;
    gap: 0.35rem;
    max-width: 28rem;
  }

  .site-nav__drawer-link,
  .site-nav__drawer-cta {
    display: flex;
    align-items: center;
    min-height: 48px;
    padding: 0.85rem 1rem;
    color: var(--color-cream);
    text-decoration: none;
    border-radius: 0.9rem;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .site-nav__drawer-link {
    background: color-mix(in srgb, var(--color-cream) 5%, transparent);
  }

  .site-nav__drawer-link.is-active,
  .site-nav__drawer-link:hover,
  .site-nav__drawer-link:focus-visible {
    background: color-mix(in srgb, var(--color-teal) 18%, transparent);
  }

  .site-nav__drawer-cta {
    justify-content: center;
    margin-top: 0.35rem;
    color: var(--color-navy);
    background: var(--color-teal);
  }

  @media (max-width: 900px) {
    .site-nav__links {
      display: none;
    }

    .site-nav__cta {
      display: none;
    }

    .site-nav__menu-btn {
      display: inline-flex;
      margin-left: auto;
    }
  }

  @media (max-width: 640px) {
    .site-nav__wordmark {
      display: none;
    }
  }
</style>

<script>
  import { gsap, ease } from "../lib/gsap";
  import { scrollTo } from "../lib/lenis";
  import { prefersReducedMotion } from "../lib/motion";

  const nav = document.querySelector<HTMLElement>("[data-nav]");
  if (nav) initNav(nav);

  function initNav(nav: HTMLElement) {
    const reduced = prefersReducedMotion();
    const isHome = nav.dataset.navHome === "true";
    const hero = document.querySelector<HTMLElement>("#hero");
    const menuBtn = nav.querySelector<HTMLButtonElement>("[data-nav-menu-btn]");
    const menuLabel = nav.querySelector<HTMLElement>("[data-nav-menu-label]");
    const drawer = nav.querySelector<HTMLElement>("[data-nav-drawer]");
    let visible = nav.classList.contains("is-visible");
    let menuOpen = false;

    const measure = () => {
      const height = nav.querySelector(".site-nav__inner")?.getBoundingClientRect().height ?? 72;
      document.documentElement.style.setProperty("--nav-height", `${height}px`);
      document.documentElement.style.setProperty("--scroll-offset", `${height + 12}px`);
    };

    measure();
    window.addEventListener("resize", measure);

    const show = (instant = false) => {
      if (visible) return;
      visible = true;
      nav.classList.add("is-visible");
      if (reduced) return;
      gsap.to(nav, {
        y: 0,
        opacity: 1,
        duration: instant ? 0 : 0.5,
        ease: ease.soft,
      });
    };

    const hide = (instant = false) => {
      if (!visible || nav.classList.contains("is-static")) return;
      visible = false;
      nav.classList.remove("is-visible");
      if (reduced) return;
      gsap.to(nav, {
        y: "-100%",
        opacity: 0,
        duration: instant ? 0 : 0.3,
        ease: ease.inOut,
      });
    };

    if (isHome && hero) {
      if (!reduced) gsap.set(nav, { y: "-100%", opacity: 0 });
      const obs = new IntersectionObserver(
        ([entry]) => (entry.isIntersecting ? hide() : show()),
        { threshold: 0 }
      );
      obs.observe(hero);
    } else {
      nav.classList.add("is-visible", "is-static");
      if (!reduced) gsap.set(nav, { clearProps: "transform,opacity" });
    }

    const setMenu = (open: boolean) => {
      menuOpen = open;
      nav.toggleAttribute("data-menu-open", open);
      if (menuBtn) menuBtn.setAttribute("aria-expanded", String(open));
      if (menuLabel) menuLabel.textContent = open ? "Close" : "Menu";
      if (drawer) drawer.hidden = !open;
      document.body.style.overflow = open ? "hidden" : "";
      measure();
      if (open) {
        drawer?.querySelector<HTMLElement>("a")?.focus();
      }
    };

    menuBtn?.addEventListener("click", () => setMenu(!menuOpen));

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && menuOpen) {
        setMenu(false);
        menuBtn?.focus();
      }
    });

    document.addEventListener("click", (event) => {
      if (!menuOpen) return;
      const target = event.target as Node | null;
      if (target && !nav.contains(target)) setMenu(false);
    });

    nav.querySelectorAll<HTMLAnchorElement>("a[href]").forEach((a) => {
      a.addEventListener("click", (e) => {
        const href = a.getAttribute("href");
        if (!href) return;

        if (menuOpen) setMenu(false);

        if (href.startsWith("#")) {
          e.preventDefault();
          scrollTo(href);
          history.pushState(null, "", href);
          return;
        }

        if (href.startsWith("/#") && isHome) {
          e.preventDefault();
          const hash = href.slice(1);
          scrollTo(hash);
          history.pushState(null, "", hash);
        }
      });
    });
  }
</script>
