---
/**
 * Manifesto — scroll-scrubbed, word-by-word reveal of the agency thesis.
 *
 * The marquee headline is split into word <span>s in JS. Each word is revealed
 * (opacity + y) as the user scrubs through a 180vh pinned section. The final
 * paragraph fades in at the end of the pin.
 *
 * Reduced-motion: all words visible, no pin, no JS animation.
 */
---

<section
  id="manifesto"
  class="manifesto section-shell"
  data-manifesto
  data-tone="dark"
  aria-labelledby="manifesto-title"
>
  <div class="manifesto__inner">
    <p class="eyebrow manifesto__eyebrow">The Manifesto</p>

    <h2 id="manifesto-title" class="manifesto__headline" data-manifesto-headline>
      We pair the best people with AI to
      supercharge&nbsp;<span class="text-gradient-overlap">everything.</span>
    </h2>

    <div class="manifesto__body" data-manifesto-body>
      <p>
        Elite strategists, marketers, and engineers, wired into AI across
        the entire build. Creative, growth, and software, all on one&nbsp;system.
      </p>
      <p>
        The result compounds. More performance, more creativity, faster
        cycles, and the human judgment to decide what actually&nbsp;ships.
      </p>
    </div>
  </div>

  <!-- Ambient grid backdrop -->
  <div class="manifesto__bg" aria-hidden="true">
    <span class="manifesto__blob manifesto__blob--purple"></span>
    <span class="manifesto__blob manifesto__blob--teal"></span>
  </div>
</section>

<style>
  .manifesto {
    position: relative;
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--color-navy);
    overflow: clip;
    isolation: isolate;
    text-align: center;
  }

  .manifesto__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .manifesto__blob {
    position: absolute;
    width: 50vmax;
    height: 50vmax;
    border-radius: 50%;
    filter: blur(110px);
    opacity: 0.15;
    will-change: transform;
  }
  .manifesto__blob--purple {
    top: -15vmax;
    left: -15vmax;
    background: radial-gradient(circle, var(--color-purple) 0%, transparent 65%);
  }
  .manifesto__blob--teal {
    bottom: -15vmax;
    right: -15vmax;
    background: radial-gradient(circle, var(--color-teal) 0%, transparent 65%);
  }

  .manifesto__inner {
    position: relative;
    z-index: 1;
    max-width: 56rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(1.5rem, 4vh, 3rem);
  }

  .manifesto__eyebrow {
    color: color-mix(in srgb, var(--color-cream) 42%, transparent);
  }

  .manifesto__headline {
    font-size: var(--text-display-lg);
    line-height: 1.12;
    letter-spacing: var(--text-display-lg--letter-spacing);
    will-change: contents;
    /* Give descenders ("g"/"p" in "supercharge") room: the inline-block word
       spans below clip to a tight box, so without bottom padding the final
       line's tails get cut by the section's overflow: clip. */
    padding-bottom: 0.15em;
  }

  /* Word-reveal spans injected by JS */
  .manifesto__headline :global(.word) {
    display: inline-block;
    /* pad + offset so transformed glyphs keep their descenders inside the box */
    padding-bottom: 0.08em;
    margin-bottom: -0.08em;
    will-change: opacity, transform;
  }

  /* The payoff word lives inside .text-gradient-overlap, which paints its
     gradient and clips it to ITS OWN text. Wrapping that text in a child
     .word span left the child as plain `color: transparent` text with no
     background of its own — i.e. invisible. Re-apply the clipped gradient to
     the inner word so "everything." actually renders. */
  .manifesto__headline :global(.text-gradient-overlap .word) {
    background: var(--gradient-overlap);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .manifesto__body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 38rem;
    font-size: var(--text-lead);
    line-height: var(--text-lead--line-height);
    color: color-mix(in srgb, var(--color-cream) 68%, transparent);
    will-change: opacity, transform;
  }
  .manifesto__body p + p {
    color: color-mix(in srgb, var(--color-cream) 50%, transparent);
  }
</style>

<script>
  import { initGsap, gsap, ScrollTrigger } from "../lib/gsap";
  import { prefersReducedMotion } from "../lib/motion";

  const root = document.querySelector<HTMLElement>("[data-manifesto]");
  if (root) initManifesto(root);

  function initManifesto(root: HTMLElement) {
    if (prefersReducedMotion()) return;

    initGsap();

    const headline = root.querySelector<HTMLElement>("[data-manifesto-headline]")!;
    const body = root.querySelector<HTMLElement>("[data-manifesto-body]")!;

    // Split headline text nodes into word spans (preserve child elements like
    // the gradient span — walk text nodes only).
    walkTextNodes(headline, (node) => {
      const words = node.textContent?.split(/(\s+)/) ?? [];
      const frag = document.createDocumentFragment();
      words.forEach((chunk) => {
        if (/^\s+$/.test(chunk)) {
          frag.appendChild(document.createTextNode(chunk));
        } else if (chunk) {
          const span = document.createElement("span");
          span.className = "word";
          span.textContent = chunk;
          frag.appendChild(span);
        }
      });
      node.parentNode?.replaceChild(frag, node);
    });

    const words = Array.from(headline.querySelectorAll<HTMLElement>(".word"));

    // Separate the gradient payoff word ("everything.") from the setup words so
    // it can land as its own emphasized beat. Without this, it staggers in
    // last and the headline reads as the truncated "...supercharge" for
    // most of the scrub.
    const payoff = headline.querySelector<HTMLElement>(
      ".text-gradient-overlap .word, .text-gradient-overlap"
    );
    const setupWords = words.filter((w) => w !== payoff);

    // Reduce-motion guard already returned, so build the scrub.
    const tl = gsap.timeline({
      defaults: { ease: "none" },
      scrollTrigger: {
        trigger: root,
        start: "top 75%",
        end: "bottom 55%",
        scrub: 1.2,
        invalidateOnRefresh: true,
      },
    });

    // Setup words stagger in over the first ~quarter of the scrub, so the
    // payoff can punch in early and the COMPLETE sentence — never a dangling
    // "...supercharge" fragment — is the resting state for most of the scroll.
    tl.from(setupWords, {
      opacity: 0,
      y: 30,
      stagger: 0.22 / setupWords.length,
      ease: "power2.out",
      duration: 0.25,
    }, 0);

    // Payoff lands right behind the last setup word and finishes by ~40% of the
    // scrub, so the full headline holds for the entire back half.
    if (payoff) {
      tl.from(payoff, {
        opacity: 0,
        y: 40,
        scale: 0.92,
        transformOrigin: "left center",
        ease: "power3.out",
        duration: 0.2,
      }, 0.22);
    }

    // Body fades in once the headline has landed — kept mid-scrub (not the tail)
    // so the full copy is settled well before the section scrolls past.
    tl.from(body, {
      opacity: 0,
      y: 28,
      ease: "power2.out",
      duration: 0.3,
    }, 0.5);

    ScrollTrigger.refresh();
  }

  function walkTextNodes(el: Element, fn: (node: Text) => void) {
    const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, {
      acceptNode: (n) =>
        n.textContent?.trim()
          ? NodeFilter.FILTER_ACCEPT
          : NodeFilter.FILTER_SKIP,
    });
    const nodes: Text[] = [];
    let node: Text;
    while ((node = walker.nextNode() as Text)) nodes.push(node);
    nodes.forEach(fn);
  }
</script>
