---
/**
 * Manifesto — scroll-scrubbed, word-by-word reveal of the agency thesis.
 *
 * The marquee headline is split into word <span>s in JS. Each word is revealed
 * (opacity + y) as the user scrubs through a 180vh pinned section. The final
 * paragraph fades in at the end of the pin.
 *
 * Reduced-motion: all words visible, no pin, no JS animation.
 */
---

<section
  id="manifesto"
  class="manifesto section-shell"
  data-manifesto
  data-tone="dark"
  aria-labelledby="manifesto-title"
>
  <div class="manifesto__inner">
    <p class="eyebrow manifesto__eyebrow">The Manifesto</p>

    <h2 id="manifesto-title" class="manifesto__headline" data-manifesto-headline>
      We don't replace the best&nbsp;people.
      We give them&nbsp;<span class="text-gradient-overlap">leverage.</span>
    </h2>

    <div class="manifesto__body" data-manifesto-body>
      <p>
        Top tier strategists, writers, and creative directors, wired into
        AI at every stage. Not a shortcut. A compounding advantage that
        gets sharper with every project.
      </p>
      <p>
        Faster cycles. Wider exploration. Frictionless operations. And the
        human judgment to know what actually&nbsp;ships.
      </p>
    </div>
  </div>

  <!-- Ambient grid backdrop -->
  <div class="manifesto__bg" aria-hidden="true">
    <span class="manifesto__blob manifesto__blob--purple"></span>
    <span class="manifesto__blob manifesto__blob--teal"></span>
  </div>
</section>

<style>
  .manifesto {
    position: relative;
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--color-navy);
    overflow: clip;
    isolation: isolate;
    text-align: center;
  }

  .manifesto__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .manifesto__blob {
    position: absolute;
    width: 50vmax;
    height: 50vmax;
    border-radius: 50%;
    filter: blur(110px);
    opacity: 0.15;
    will-change: transform;
  }
  .manifesto__blob--purple {
    top: -15vmax;
    left: -15vmax;
    background: radial-gradient(circle, var(--color-purple) 0%, transparent 65%);
  }
  .manifesto__blob--teal {
    bottom: -15vmax;
    right: -15vmax;
    background: radial-gradient(circle, var(--color-teal) 0%, transparent 65%);
  }

  .manifesto__inner {
    position: relative;
    z-index: 1;
    max-width: 56rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(1.5rem, 4vh, 3rem);
  }

  .manifesto__eyebrow {
    color: color-mix(in srgb, var(--color-cream) 42%, transparent);
  }

  .manifesto__headline {
    font-size: var(--text-display-lg);
    line-height: 1.08;
    letter-spacing: var(--text-display-lg--letter-spacing);
    will-change: contents;
  }

  /* Word-reveal spans injected by JS */
  .manifesto__headline :global(.word) {
    display: inline-block;
    will-change: opacity, transform;
  }

  .manifesto__body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 38rem;
    font-size: var(--text-lead);
    line-height: var(--text-lead--line-height);
    color: color-mix(in srgb, var(--color-cream) 68%, transparent);
    will-change: opacity, transform;
  }
  .manifesto__body p + p {
    color: color-mix(in srgb, var(--color-cream) 50%, transparent);
  }
</style>

<script>
  import { initGsap, gsap, ScrollTrigger } from "../lib/gsap";
  import { prefersReducedMotion } from "../lib/motion";

  const root = document.querySelector<HTMLElement>("[data-manifesto]");
  if (root) initManifesto(root);

  function initManifesto(root: HTMLElement) {
    if (prefersReducedMotion()) return;

    initGsap();

    const headline = root.querySelector<HTMLElement>("[data-manifesto-headline]")!;
    const body = root.querySelector<HTMLElement>("[data-manifesto-body]")!;

    // Split headline text nodes into word spans (preserve child elements like
    // the gradient span — walk text nodes only).
    walkTextNodes(headline, (node) => {
      const words = node.textContent?.split(/(\s+)/) ?? [];
      const frag = document.createDocumentFragment();
      words.forEach((chunk) => {
        if (/^\s+$/.test(chunk)) {
          frag.appendChild(document.createTextNode(chunk));
        } else if (chunk) {
          const span = document.createElement("span");
          span.className = "word";
          span.textContent = chunk;
          frag.appendChild(span);
        }
      });
      node.parentNode?.replaceChild(frag, node);
    });

    const words = Array.from(headline.querySelectorAll<HTMLElement>(".word"));

    // Reduce-motion guard already returned, so build the scrub.
    const tl = gsap.timeline({
      defaults: { ease: "none" },
      scrollTrigger: {
        trigger: root,
        start: "top 55%",
        end: "bottom 45%",
        scrub: 1.2,
        invalidateOnRefresh: true,
      },
    });

    // Words stagger in over 0–0.78 of the scrub.
    tl.from(words, {
      opacity: 0,
      y: 30,
      stagger: 0.85 / words.length,
      ease: "power2.out",
      duration: 0.85,
    }, 0);

    // Body fades in at the tail.
    tl.from(body, {
      opacity: 0,
      y: 28,
      ease: "power2.out",
      duration: 0.35,
    }, 0.65);

    ScrollTrigger.refresh();
  }

  function walkTextNodes(el: Element, fn: (node: Text) => void) {
    const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, {
      acceptNode: (n) =>
        n.textContent?.trim()
          ? NodeFilter.FILTER_ACCEPT
          : NodeFilter.FILTER_SKIP,
    });
    const nodes: Text[] = [];
    let node: Text;
    while ((node = walker.nextNode() as Text)) nodes.push(node);
    nodes.forEach(fn);
  }
</script>
