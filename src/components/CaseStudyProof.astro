---
import type { CaseStudy } from "../data/caseStudies";

interface Props {
  study: CaseStudy;
}

const { study } = Astro.props;
---

<section class="story-proof" data-story-proof aria-label="Headline outcomes">
  <div class="story-proof__inner">
    <p class="story-proof__label">What moved</p>
    <dl class="story-proof__metrics">
      {
        study.metrics.map((metric) => (
          <div>
            <dd data-story-metric>{metric.value}</dd>
            <dt>{metric.label}</dt>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .story-proof {
    padding-inline: var(--spacing-gutter);
    padding-block: clamp(2rem, 5vh, 3.5rem);
    color: var(--color-cream);
    background: var(--color-navy);
    border-block: 1px solid color-mix(in srgb, var(--color-cream) 10%, transparent);
  }

  .story-proof__inner {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: end;
    max-width: 88rem;
    margin-inline: auto;
  }

  .story-proof__label {
    margin: 0;
    color: color-mix(in srgb, var(--color-cream) 48%, transparent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .story-proof__metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: clamp(1.25rem, 3vw, 2.5rem);
    margin: 0;
  }

  .story-proof__metrics div {
    min-width: 0;
  }

  .story-proof__metrics dd {
    margin: 0;
    color: var(--color-teal);
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5.5vw, 4.8rem);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    letter-spacing: -0.05em;
    line-height: 0.88;
  }

  .story-proof__metrics dt {
    margin-top: 0.55rem;
    color: color-mix(in srgb, var(--color-cream) 56%, transparent);
    font-size: 0.84rem;
    line-height: 1.35;
  }

  @media (max-width: 640px) {
    .story-proof__inner {
      grid-template-columns: minmax(0, 1fr);
      gap: 1.25rem;
    }
  }
</style>
