---
import { getCaseStudyHref, type CaseStudy } from "../data/caseStudies";

interface Props {
  study: CaseStudy;
  index?: number;
}

const { study, index = 0 } = Astro.props;
const href = getCaseStudyHref(study);
const glowX = `${Math.max(42, 82 - index * 8)}%`;
---

<article class="case-card" style={`--card-glow-x: ${glowX};`}>
  <a href={href} class="case-card__link" data-cursor="link" aria-label={`Read case study: ${study.title}`}>
    <div class="case-card__copy">
      <p class="case-card__meta">
        <span>{study.year}</span>
        <span aria-hidden="true">/</span>
        <span>{study.industry}</span>
      </p>
      <h4 class="case-card__title">{study.title}</h4>
      <p class="case-card__description">{study.catalogSummary}</p>
    </div>

    <dl class="case-card__metrics" aria-label="Headline outcomes">
      {
        study.metrics.slice(0, 3).map((metric) => (
          <div class="case-card__metric">
            <dt>{metric.label}</dt>
            <dd>{metric.value}</dd>
          </div>
        ))
      }
    </dl>

    <div class="case-card__footer">
      <ul class="case-card__steps" aria-label="Story sections">
        {study.steps.map((step) => <li>{step.label}</li>)}
      </ul>
      <span class="case-card__cta">
        Read the story
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M4 9h10M10 5l4 4-4 4" />
        </svg>
      </span>
    </div>
  </a>
</article>

<style>
  .case-card {
    position: relative;
    overflow: clip;
    color: var(--color-cream);
    background:
      radial-gradient(
        circle at var(--card-glow-x) 12%,
        color-mix(in srgb, var(--color-teal) 15%, transparent),
        transparent 28rem
      ),
      radial-gradient(
        circle at 12% 92%,
        color-mix(in srgb, var(--color-purple) 13%, transparent),
        transparent 24rem
      ),
      var(--color-navy);
    border-radius: clamp(1.25rem, 2.5vw, 2rem);
    box-shadow: 0 2rem 5rem color-mix(in srgb, var(--color-navy) 20%, transparent);
  }

  .case-card__link {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(17rem, 0.9fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    min-height: clamp(28rem, 46vw, 38rem);
    padding: clamp(1.4rem, 4vw, 4.5rem);
    color: inherit;
    text-decoration: none;
  }

  .case-card__link::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border: 1px solid color-mix(in srgb, var(--color-cream) 11%, transparent);
    border-radius: clamp(1.25rem, 2.5vw, 2rem);
  }

  .case-card__copy {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    max-width: 46rem;
  }

  .case-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0 0 1.35rem;
    color: color-mix(in srgb, var(--color-cream) 53%, transparent);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .case-card__meta span:nth-child(2) {
    color: var(--color-teal);
  }

  .case-card__title {
    max-width: 13ch;
    margin: 0;
    font-size: clamp(2.05rem, 5vw, 5.4rem);
    line-height: 0.96;
    letter-spacing: -0.035em;
  }

  .case-card__description {
    max-width: 42rem;
    margin: 1.4rem 0 0;
    color: color-mix(in srgb, var(--color-cream) 72%, transparent);
    font-size: clamp(1rem, 1.45vw, 1.2rem);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .case-card__metrics {
    display: grid;
    align-self: end;
    gap: 1rem;
    margin: 0;
  }

  .case-card__metric {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: end;
    padding-top: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--color-cream) 18%, transparent);
  }

  .case-card__metric dt {
    max-width: 14rem;
    color: color-mix(in srgb, var(--color-cream) 55%, transparent);
    font-size: 0.82rem;
    line-height: 1.35;
  }

  .case-card__metric dd {
    margin: 0;
    color: var(--color-teal);
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4.4vw, 4.6rem);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 0.8;
  }

  .case-card__footer {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: clamp(1.25rem, 3vw, 2rem);
    border-top: 1px solid color-mix(in srgb, var(--color-cream) 13%, transparent);
  }

  .case-card__steps {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .case-card__steps li {
    padding: 0.5rem 0.7rem;
    color: color-mix(in srgb, var(--color-cream) 67%, transparent);
    background: color-mix(in srgb, var(--color-cream) 7%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-cream) 12%, transparent);
    border-radius: 0.7rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .case-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-teal-bright);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .case-card__cta svg {
    transition: transform var(--duration-fast) var(--ease-out-soft);
  }

  .case-card__cta path {
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .case-card__link:hover .case-card__cta svg,
  .case-card__link:focus-visible .case-card__cta svg {
    transform: translateX(0.25rem);
  }

  @media (max-width: 900px) {
    .case-card__link {
      grid-template-columns: minmax(0, 1fr);
      min-height: 0;
    }
  }

  @media (max-width: 560px) {
    .case-card__metrics {
      grid-template-columns: minmax(0, 1fr);
    }

    .case-card__metric {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: end;
    }

    .case-card__footer {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
