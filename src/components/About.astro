---
/**
 * About — "The humans"
 * Brief team beat: operators who grew consumer businesses from the inside.
 * Pedigree chips (no named individuals) + three beliefs.
 * Dark navy section for tonal rhythm.
 */

// Team pedigree — backgrounds the senior team brings, no named individuals.
const credentials = [
  "P&L Ownership",
  "Organic Growth",
  "Tier One Strategy",
  "Brand & Creative",
  "Software Engineering",
];

const beliefs = [
  "We understand the problem before we touch the solution.",
  "We never ship anything we would not put our name on.",
  "You get the people who run the studio, not juniors on your account.",
];
---

<section
  id="about"
  class="about section-shell"
  data-about
  data-tone="dark"
  aria-labelledby="about-title"
>
  <div class="about__intro">
    <p class="eyebrow about__eyebrow">About</p>
    <h2 id="about-title" class="about__headline">
      The&nbsp;<span class="text-gradient-overlap">humans.</span>
    </h2>
    <p class="about__lead">
      We are operators, marketers, and engineers who spent years growing
      consumer businesses from the inside. Now we do it for clients.
    </p>
  </div>

  <!-- Pedigree -->
  <div class="about__pedigree" data-pedigree>
    <p class="about__body about__pedigree-text">
      Senior specialists, not juniors. The backgrounds on your account:
    </p>
    <ul class="about__creds" aria-label="Team backgrounds">
      {credentials.map((c) => <li class="about__cred">{c}</li>)}
    </ul>
  </div>

  <!-- Beliefs -->
  <div class="about__beliefs" data-beliefs>
    <p class="eyebrow about__beliefs-label">What we believe</p>
    <ul class="about__beliefs-list">
      {beliefs.map((b) => (
        <li class="about__belief">
          <span class="about__belief-mark" aria-hidden="true">→</span>
          {b}
        </li>
      ))}
    </ul>
  </div>

  <div class="about__bg" aria-hidden="true">
    <span class="about__blob about__blob--purple"></span>
    <span class="about__blob about__blob--teal"></span>
  </div>
</section>

<style>
  .about {
    position: relative;
    background-color: var(--color-navy-800);
    color: var(--color-cream);
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 7vh, 5rem);
    overflow: clip;
    isolation: isolate;
  }

  .about__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .about__blob {
    position: absolute;
    width: 46vmax;
    height: 46vmax;
    border-radius: 50%;
    filter: blur(110px);
    opacity: 0.1;
  }
  .about__blob--purple {
    top: -8vmax; right: -12vmax;
    background: radial-gradient(circle, var(--color-purple) 0%, transparent 65%);
  }
  .about__blob--teal {
    bottom: -8vmax; left: -12vmax;
    background: radial-gradient(circle, var(--color-teal) 0%, transparent 65%);
  }

  /* ---------- Intro ---------- */
  .about__intro {
    position: relative;
    z-index: 1;
    max-width: 46rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .about__eyebrow {
    color: color-mix(in srgb, var(--color-cream) 40%, transparent);
  }
  .about__headline {
    font-size: var(--text-display-lg);
    line-height: var(--text-display-lg--line-height);
    letter-spacing: var(--text-display-lg--letter-spacing);
  }
  .about__lead {
    font-size: var(--text-lead);
    line-height: var(--text-lead--line-height);
    color: color-mix(in srgb, var(--color-cream) 78%, transparent);
    font-style: normal;
  }
  .about__lead em { font-style: normal; font-weight: 600; }
  .about__body {
    font-size: 1rem;
    line-height: 1.7;
    color: color-mix(in srgb, var(--color-cream) 58%, transparent);
    max-width: 42rem;
  }
  .about__body + .about__body {
    margin-top: 1rem;
  }

  /* ---------- Pedigree ---------- */
  .about__pedigree {
    position: relative;
    z-index: 1;
    max-width: 46rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .about__pedigree-text {
    max-width: 44rem;
  }
  .about__creds {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .about__cred {
    padding: 0.45rem 0.9rem;
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-cream);
    background: color-mix(in srgb, var(--color-cream) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-cream) 16%, transparent);
    border-radius: var(--radius-pill);
  }

  /* ---------- Beliefs ---------- */
  .about__beliefs {
    position: relative;
    z-index: 1;
    max-width: 40rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .about__beliefs-label {
    color: color-mix(in srgb, var(--color-cream) 38%, transparent);
  }
  .about__beliefs-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .about__belief {
    display: flex;
    gap: 0.75rem;
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    line-height: 1.5;
    color: color-mix(in srgb, var(--color-cream) 80%, transparent);
    font-family: var(--font-display);
    font-weight: 500;
  }
  .about__belief-mark {
    color: var(--color-teal);
    flex-shrink: 0;
  }
</style>

<script>
  import { reveal } from "../lib/reveal";
  import { prefersReducedMotion } from "../lib/motion";

  const root = document.querySelector<HTMLElement>("[data-about]");
  if (root) initAbout(root);

  function initAbout(root: HTMLElement) {
    if (prefersReducedMotion()) return;

    reveal(root.querySelector(".about__intro"));
    reveal(root.querySelector(".about__pedigree-text"));
    reveal(root.querySelectorAll<HTMLElement>(".about__cred"), {
      trigger: root.querySelector(".about__creds"),
    });
    reveal(root.querySelector("[data-beliefs]"));
  }
</script>
