---
/**
 * Footer — minimal, on-brand.
 * Wordmark, nav links, socials, "Made by humans + machines" line, year.
 */
import logoMarkRaw from "../assets/logo-mark.svg?raw";
import { primaryNavLinks, resolveNavHref } from "../data/siteNav";

const year = new Date().getFullYear();
const pathname = Astro.url.pathname;
const isHome = pathname === "/" || pathname === "";

const links = [
  ...primaryNavLinks.map((link) => ({
    label: link.label,
    href: resolveNavHref(link, pathname),
  })),
  { label: "Work with us", href: isHome ? "#cta" : "/#cta" },
];

const legalLinks = [
  { label: "Contact", href: "/contact" },
  { label: "Privacy", href: "/privacy" },
  { label: "Terms", href: "/terms" },
];
---

<footer class="site-footer" role="contentinfo">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <a href={isHome ? "#hero" : "/"} class="site-footer__logo" data-cursor="link" aria-label="Back to top: Cookies and Tokens">
        <span class="site-footer__mark" set:html={logoMarkRaw} />
        <span class="site-footer__wordmark">
          Cookies&nbsp;&amp;&nbsp;Tokens
        </span>
      </a>
      <p class="site-footer__tagline">Growth for consumer businesses, run by operators.</p>
    </div>

    <nav class="site-footer__nav" aria-label="Footer navigation">
      <ul class="site-footer__links">
        {links.map((l) => (
          <li>
            <a href={l.href} class="site-footer__link" data-cursor="link">
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <nav class="site-footer__nav" aria-label="Legal navigation">
      <ul class="site-footer__links">
        {legalLinks.map((l) => (
          <li>
            <a href={l.href} class="site-footer__link" data-cursor="link">
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="site-footer__bottom">
    <p class="site-footer__made">
      Made by&nbsp;
      <span class="site-footer__made-purple">humans</span>
      &nbsp;and&nbsp;
      <span class="site-footer__made-teal">machines</span>.
    </p>
    <p class="site-footer__copy">
      &copy; {year} Cookies &amp; Tokens. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-navy);
    border-top: 1px solid color-mix(in srgb, var(--color-cream) 8%, transparent);
    padding-inline: var(--spacing-gutter);
  }

  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: flex-start;
    padding-block: clamp(3rem, 6vh, 5rem);
    max-width: 72rem;
    margin-inline: auto;
  }

  .site-footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    min-width: 180px;
  }
  .site-footer__logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--color-cream);
  }
  .site-footer__mark {
    width: 36px;
    flex-shrink: 0;
  }
  .site-footer__mark :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }
  .site-footer__wordmark {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .site-footer__tagline {
    font-size: 0.8125rem;
    color: color-mix(in srgb, var(--color-cream) 38%, transparent);
    margin-left: calc(36px + 0.6rem);
  }

  .site-footer__nav { flex: 1; min-width: 160px; }
  .site-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .site-footer__link {
    font-size: 0.875rem;
    color: color-mix(in srgb, var(--color-cream) 55%, transparent);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-soft);
  }
  .site-footer__link:hover { color: var(--color-cream); }

  .site-footer__bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    padding-block: 1.25rem;
    border-top: 1px solid color-mix(in srgb, var(--color-cream) 7%, transparent);
    max-width: 72rem;
    margin-inline: auto;
  }
  .site-footer__made,
  .site-footer__copy {
    font-size: 0.8125rem;
    color: color-mix(in srgb, var(--color-cream) 35%, transparent);
    margin: 0;
  }
  .site-footer__made-purple { color: var(--color-purple); }
  .site-footer__made-teal   { color: var(--color-teal); }
</style>

<script>
  import { scrollTo } from "../lib/lenis";

  const isHome = window.location.pathname === "/" || window.location.pathname === "";

  document
    .querySelectorAll<HTMLAnchorElement>(".site-footer a[href]")
    .forEach((a) => {
      a.addEventListener("click", (e) => {
        const href = a.getAttribute("href");
        if (!href) return;

        if (href.startsWith("#")) {
          e.preventDefault();
          scrollTo(href);
          history.pushState(null, "", href);
          return;
        }

        if (href.startsWith("/#") && isHome) {
          e.preventDefault();
          const hash = href.slice(1);
          scrollTo(hash);
          history.pushState(null, "", hash);
        }
      });
    });
</script>
