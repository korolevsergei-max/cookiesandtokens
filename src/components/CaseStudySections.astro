---
import type { CaseStudy } from "../data/caseStudies";
import CaseStudyVisual from "./CaseStudyVisual.astro";

interface Props {
  study: CaseStudy;
}

const { study } = Astro.props;
---

<div class="story-narrative" data-story-narrative>
  {
    study.steps.map((step, index) => (
      <section
        class="story-chapter"
        data-story-chapter
        aria-labelledby={`${study.slug}-${step.id}-title`}
      >
        <div class="story-chapter__copy">
          <p class="story-chapter__number" aria-hidden="true">{step.number}</p>
          <h2 id={`${study.slug}-${step.id}-title`}>{step.title}</h2>
          {step.body.map((paragraph) => <p>{paragraph}</p>)}
          <ul class="story-chapter__tags" aria-label="Related themes">
            {step.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        </div>
        <CaseStudyVisual step={step} preferAbstract={index === 0 && Boolean(step.visual.image)} />
      </section>
    ))
  }

  <p class="story-narrative__disclosure">{study.disclosure}</p>
</div>

<style>
  .story-narrative {
    display: grid;
    gap: clamp(4rem, 9vw, 7.5rem);
    padding-inline: var(--spacing-gutter);
    padding-block: clamp(3.5rem, 9vh, 7rem);
    color: var(--color-cream);
    background: var(--color-navy);
  }

  .story-chapter {
    display: grid;
    grid-template-columns: minmax(16rem, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
    max-width: 88rem;
    margin-inline: auto;
  }

  .story-chapter:nth-child(even) .story-chapter__copy {
    order: 2;
  }

  .story-chapter__copy {
    max-width: 38rem;
  }

  .story-chapter__number {
    margin: 0 0 0.85rem;
    color: var(--color-teal);
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .story-chapter h2 {
    margin: 0;
    font-size: clamp(2rem, 4.2vw, 4.2rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .story-chapter p:not(.story-chapter__number) {
    margin: 1.2rem 0 0;
    color: color-mix(in srgb, var(--color-cream) 72%, transparent);
    font-size: clamp(1rem, 1.35vw, 1.14rem);
    line-height: 1.7;
    text-wrap: pretty;
  }

  .story-chapter__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding: 0;
    margin: 1.5rem 0 0;
    list-style: none;
  }

  .story-chapter__tags li {
    padding: 0.45rem 0.7rem;
    color: color-mix(in srgb, var(--color-cream) 78%, transparent);
    background: color-mix(in srgb, var(--color-cream) 7%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-cream) 12%, transparent);
    border-radius: 0.75rem;
    font-size: 0.74rem;
    font-weight: 600;
  }

  .story-narrative__disclosure {
    max-width: 88rem;
    margin: 0 auto;
    color: color-mix(in srgb, var(--color-cream) 43%, transparent);
    font-size: 0.78rem;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .story-chapter {
      grid-template-columns: minmax(0, 1fr);
    }

    .story-chapter:nth-child(even) .story-chapter__copy {
      order: 0;
    }
  }
</style>
