---
/**
 * OfferingGrowth — the "Momentum Plot".
 *
 * Growth is the only Offering section that claims four channels run as ONE
 * engine, so all four are readable at once rather than revealed one at a time.
 * The channels are plotted as stations on a single rising momentum line: the
 * canvas curve is fed the measured node positions, so it literally climbs
 * through them (see initGrowthMomentum).
 *
 * Deliberately surface-less — no panels, bezels, or chip pills. Creative owns
 * editorial rows + purple pills, Software owns the spec sheet + mono chips;
 * Growth reads as a chart drawn straight onto the navy.
 *
 * Layout modes:
 *   ≥1280px — plot band (climbing nodes + stems) above a 4-column station grid
 *   <1280px — one vertical rail with the same nodes running down the left edge
 */
import ServiceIcon from "./ServiceIcon.astro";

interface Card {
  number: string;
  title: string;
  desc: string;
  tags: string[];
}

interface Props {
  id: string;
  eyebrow?: string;
  titleLead: string;
  titleAccent: string;
  sub: string;
  cards: Card[];
  tone?: "light" | "dark";
  accent?: "purple" | "teal";
}

const {
  id,
  eyebrow,
  titleLead,
  titleAccent,
  sub,
  cards,
} = Astro.props;

const titleId = `${id}-title`;
const total = cards.length;

// Station positions inside the plot band. X sits at each column's centre; Y
// climbs so the line rises left → right. The stem then reaches from the node
// down past the band's bottom edge to the station heading beneath it.
const BAND = 180; // px — keep in sync with the band's height class below
const nodeX = (i: number) => ((i + 0.5) / total) * 100;
const nodeY = (i: number) => 80 - (i / (total - 1)) * 68;
const stem = (i: number) => `calc(${(BAND * (1 - nodeY(i) / 100)).toFixed(1)}px + 2.5rem)`;
---

<section
  id={id}
  class="growth relative overflow-clip isolation-isolate bg-navy-800 text-cream py-24 md:py-32"
  data-offering-growth
  aria-labelledby={titleId}
>
  {/* Momentum field — the climbing line + rising motes, behind everything. */}
  <canvas
    class="absolute inset-0 w-full h-full z-0 pointer-events-none"
    data-growth-motion
    aria-hidden="true"
  ></canvas>

  <div class="relative z-10 max-w-[1400px] mx-auto px-[var(--spacing-gutter)]">
    {/* Header — headline left, promise right, so it stops eating a viewport. */}
    <header class="flex flex-col md:flex-row md:items-end justify-between gap-8 md:gap-16">
      <div>
        {eyebrow && <p class="eyebrow text-teal mb-6">{eyebrow}</p>}
        <h2 id={titleId} class="text-display-lg md:text-display-xl tracking-tighter leading-none text-cream">
          {titleLead}<br /><span class="text-teal">{titleAccent}</span>
        </h2>
      </div>
      <p class="text-lead text-cream/70 max-w-[34ch] md:mb-3">
        {sub}
      </p>
    </header>

    {/* Plot band — node markers on the climb, with stems dropping to the
        stations below. Wide viewports only; the rail takes over under xl. */}
    <div class="growth-plot hidden xl:block relative h-[180px] mt-20" data-growth-plot aria-hidden="true">
      {cards.map((_c, i) => (
        <span
          class="growth-node"
          data-growth-anchor
          style={`--nx:${nodeX(i)}%; --ny:${nodeY(i)}%; --stem:${stem(i)};`}
        >
          <span class="growth-node__ring"></span>
        </span>
      ))}
    </div>

    {/* Stations */}
    <ol class="growth-stations mt-12 xl:mt-8 grid grid-cols-1 xl:grid-cols-4 gap-x-8 gap-y-14" data-growth-stations>
      {cards.map((c) => (
        <li class="growth-station relative" data-growth-station>
          <div class="flex items-center gap-3 mb-5">
            <span class="font-display text-sm font-semibold tracking-widest text-teal tabular-nums">{c.number}</span>
            <ServiceIcon title={c.title} class="w-5 h-5 text-teal-bright shrink-0" />
          </div>

          <h3 class="growth-station__title font-display text-2xl xl:text-[1.75rem] font-semibold tracking-tight leading-tight text-cream mb-3">
            {c.title}
          </h3>

          <p class="text-[15px] xl:text-base text-cream/65 leading-relaxed max-w-[46ch]">{c.desc}</p>

          <p class="growth-station__tags mt-5 max-w-[46ch]" aria-label="What this includes">
            {c.tags.map((t, ti) => (
              <>
                {ti > 0 && <span class="growth-station__sep" aria-hidden="true">·</span>}
                <span>{t}</span>
              </>
            ))}
          </p>
        </li>
      ))}
    </ol>
  </div>

  {/* Ambient background blob — base wash behind the canvas. */}
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vmax] h-[80vmax] bg-teal/5 rounded-full pointer-events-none z-0 md:blur-[120px]"
    aria-hidden="true"
  >
  </div>
</section>

<style>
  /* ── Plot band: node markers + stems ──────────────────────────────────── */
  .growth-node {
    position: absolute;
    left: var(--nx);
    top: var(--ny);
    width: 0;
    height: 0;
  }

  .growth-node__ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 13px;
    height: 13px;
    margin: -6.5px 0 0 -6.5px;
    border-radius: 50%;
    border: 1.5px solid var(--color-teal);
    background: var(--color-navy-800);
    transition:
      transform var(--duration-base) var(--ease-out-soft),
      border-color var(--duration-base) var(--ease-out-soft),
      box-shadow var(--duration-base) var(--ease-out-soft);
  }

  /* Stem: node → the station beneath it. Length varies with the climb, which
     is what makes the four columns read as plotted rather than merely offset. */
  .growth-node::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: var(--stem);
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--color-teal) 30%, transparent),
      transparent
    );
  }

  /* Hovering a station lights its node up on the line above (set from JS). */
  .growth-node.is-active .growth-node__ring {
    transform: scale(1.45);
    border-color: var(--color-teal-bright);
    box-shadow: 0 0 16px 1px color-mix(in srgb, var(--color-teal-bright) 45%, transparent);
  }

  /* ── Stations ─────────────────────────────────────────────────────────── */
  .growth-station__title {
    transition: color var(--duration-base) var(--ease-out-soft);
  }

  .growth-station:hover .growth-station__title {
    color: var(--color-teal-bright);
  }

  /* Tags as an inline mono run — no pills, no chips, no container. */
  .growth-station__tags {
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
    font-size: 0.6875rem;
    line-height: 1.9;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-teal) 78%, transparent);
  }

  .growth-station__sep {
    color: color-mix(in srgb, var(--color-cream) 28%, transparent);
    margin: 0 0.5em;
  }

  /* ── Rail (< xl): the same climb, running down the left edge ──────────── */
  @media (max-width: 1279px) {
    .growth-stations {
      border-left: 1px solid color-mix(in srgb, var(--color-teal) 22%, transparent);
      padding-left: 2rem;
    }

    .growth-station::before {
      content: "";
      position: absolute;
      top: 0.4rem;
      left: -2rem;
      width: 11px;
      height: 11px;
      margin-left: -6px;
      border-radius: 50%;
      border: 1.5px solid var(--color-teal);
      background: var(--color-navy-800);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .growth-node__ring,
    .growth-station__title {
      transition: none;
    }
  }
</style>

<script>
  import { ScrollTrigger, initGsap } from "../lib/gsap";
  import { isCoarsePointer, prefersReducedMotion } from "../lib/motion";
  import { initGrowthMomentum, type Point } from "../lib/offeringMotion";
  import { reveal } from "../lib/reveal";

  initGsap();
  const reduced = prefersReducedMotion();
  const coarse = isCoarsePointer();

  document.querySelectorAll<HTMLElement>("[data-offering-growth]").forEach((section) => {
    const canvas = section.querySelector<HTMLCanvasElement>("[data-growth-motion]");
    const plot = section.querySelector<HTMLElement>("[data-growth-plot]");
    const stations = Array.from(section.querySelectorAll<HTMLElement>("[data-growth-station]"));
    if (!canvas) return;

    const nodes = plot ? Array.from(plot.querySelectorAll<HTMLElement>("[data-growth-anchor]")) : [];

    /**
     * Station positions normalized against the canvas box, so the momentum line
     * passes through each marker. Returns null when the plot is hidden (rail
     * layout under xl) — the scene then draws its generic ascending curve.
     */
    function anchors(): Point[] | null {
      if (!plot || !nodes.length || plot.offsetParent === null) return null;
      const box = canvas!.getBoundingClientRect();
      if (!box.width || !box.height) return null;
      return nodes.map((n) => {
        const r = n.getBoundingClientRect();
        return {
          x: (r.left + r.width / 2 - box.left) / box.width,
          y: (r.top + r.height / 2 - box.top) / box.height,
        };
      });
    }

    const scene = initGrowthMomentum(canvas, { anchors });

    // Scrubbed climb: the line completes as the plot settles into view. Touch
    // and reduced-motion get the finished line, frozen — scroll stays native.
    if (!reduced && !coarse) {
      ScrollTrigger.create({
        trigger: section,
        start: "top 70%",
        end: "center center",
        scrub: true,
        onUpdate: (self) => scene.setProgress(self.progress),
      });
    } else {
      scene.setProgress(1);
      scene.pause();
    }

    reveal(stations, { trigger: plot ?? stations[0] });

    // Hovering a station lights its node on the line above it.
    if (!coarse && nodes.length === stations.length) {
      stations.forEach((station, i) => {
        const ring = nodes[i];
        station.addEventListener("mouseenter", () => ring.classList.add("is-active"));
        station.addEventListener("mouseleave", () => ring.classList.remove("is-active"));
      });
    }
  });
</script>
