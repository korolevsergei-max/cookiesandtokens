---
import ServiceIcon from "./ServiceIcon.astro";

interface Card {
  number: string;
  title: string;
  desc: string;
  tags: string[];
}

interface Props {
  id: string;
  eyebrow?: string;
  titleLead: string;
  titleAccent: string;
  sub: string;
  cards: Card[];
  tone?: "light" | "dark";
  accent?: "purple" | "teal";
}

const {
  id,
  eyebrow,
  titleLead,
  titleAccent,
  sub,
  cards,
} = Astro.props;

const titleId = `${id}-title`;
const total = cards.length;
---

<section
  id={id}
  class="relative overflow-clip isolation-isolate bg-navy-800 text-cream"
  data-offering-growth
  aria-labelledby={titleId}
>
  {/* Momentum field — pinned to the viewport as a section-wide backdrop the cards rise over.
      Kept OUTSIDE the GSAP-pinned stack so its negative margin can't disturb pin measurements. */}
  <div class="sticky top-0 h-[100dvh] -mb-[100dvh] pointer-events-none z-0" aria-hidden="true">
    <canvas class="w-full h-full" data-growth-motion></canvas>
  </div>

  <div class="section-shell relative z-10 max-w-[1400px] mx-auto pb-12 md:pb-24 pt-24 md:pt-40">
    {eyebrow && <p class="eyebrow text-teal mb-6">{eyebrow}</p>}
    <h2 id={titleId} class="text-display-lg md:text-display-xl tracking-tighter leading-none max-w-4xl text-cream">
      {titleLead}<br /><span class="text-teal">{titleAccent}</span>
    </h2>
    <p class="text-lead text-cream/70 max-w-2xl mt-6">
      {sub}
    </p>
  </div>

  {/* Z-Axis Sticky Cascade - GSAP target container */}
  <div class="relative z-10 pb-40" data-growth-stack-container>

    {cards.map((c, i) => (
      <div class="growth-stack-card relative z-10 sticky top-0 min-h-[100dvh] flex items-center justify-center py-12 px-4 pointer-events-none">

        {/* The visible stage panel */}
        <article class="group relative p-1.5 rounded-[2rem] bg-white/5 ring-1 ring-white/10 overflow-hidden flex flex-col w-full max-w-3xl pointer-events-auto will-change-transform shadow-[0_40px_90px_-30px_rgba(0,0,0,0.75)]">
          {/* Inner Core (Double-Bezel) */}
          <div class="relative flex flex-col flex-1 h-full rounded-[calc(2rem-6px)] bg-navy-700 p-8 md:p-12 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1)] transition-transform duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-[0.985] origin-center z-10 overflow-hidden">

            {/* Oversized ghosted stage numeral */}
            <span class="pointer-events-none absolute -top-8 -right-3 md:-top-12 md:-right-5 font-display font-semibold leading-none text-[8rem] md:text-[13rem] text-white/[0.045] select-none tabular-nums">{c.number}</span>

            <div class="flex items-center justify-between mb-8 relative z-10">
              <span class="font-display text-sm font-semibold tracking-widest text-teal tabular-nums">{c.number}</span>
              {/* Ascending stage indicator — fills as you climb 01 → 04 */}
              <div class="flex items-center gap-1.5" aria-label={`Stage ${i + 1} of ${total}`}>
                {Array.from({ length: total }).map((_, s) => (
                  <span class={`h-[3px] rounded-full transition-all duration-500 ${s <= i ? "w-7 bg-teal-bright" : "w-3 bg-white/15"}`}></span>
                ))}
              </div>
            </div>

            {/* Service mark */}
            <div class="relative z-10 mb-7">
              <span class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-teal/10 ring-1 ring-teal/15 text-teal-bright shadow-[inset_0_1px_1px_rgba(255,255,255,0.12)] transition-transform duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-105 group-hover:-translate-y-0.5">
                <ServiceIcon title={c.title} class="w-7 h-7" />
              </span>
            </div>

            <div class="flex-1 relative z-10">
              <h3 class="font-display text-3xl md:text-4xl font-semibold tracking-tight text-cream mb-4">{c.title}</h3>
              <p class="text-lg md:text-xl text-cream/70 leading-relaxed max-w-[45ch]">{c.desc}</p>
            </div>

            <ul class="flex flex-wrap gap-2 mt-12 relative z-10" aria-label="What this includes">
              {c.tags.map((t) => (
                <li class="px-3 py-1 text-[10px] uppercase font-semibold tracking-widest text-teal-bright bg-teal/15 rounded-full ring-1 ring-teal/20">
                  {t}
                </li>
              ))}
            </ul>

          </div>
        </article>
      </div>
    ))}
  </div>

  {/* Ambient background blob for dark mode (base wash behind the canvas) */}
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vmax] h-[80vmax] bg-teal/5 blur-[120px] rounded-full pointer-events-none z-0"></div>
</section>

<script>
  import { gsap, ScrollTrigger, initGsap } from "../lib/gsap";
  import { prefersReducedMotion } from "../lib/motion";
  import { initGrowthMomentum } from "../lib/offeringMotion";

  initGsap();
  const reduced = prefersReducedMotion();

  document.querySelectorAll<HTMLElement>("[data-offering-growth]").forEach((section) => {
    const container = section.querySelector<HTMLElement>("[data-growth-stack-container]");
    if (!container) return;

    // Momentum field
    const canvas = section.querySelector<HTMLCanvasElement>("[data-growth-motion]");
    const scene = canvas ? initGrowthMomentum(canvas) : null;

    // Feed scroll progress so the line literally grows as cards advance.
    if (scene && !reduced) {
      ScrollTrigger.create({
        trigger: container,
        start: "top top",
        end: "bottom bottom",
        onUpdate: (self) => scene.setProgress(self.progress),
      });
    }

    // Desktop-only Z-axis stack pin/fade. On mobile, `sticky min-h-[100dvh]`
    // gives a simple sticky stack on its own.
    if (!reduced && window.innerWidth >= 768) {
      const cards = gsap.utils.toArray<HTMLElement>(container.querySelectorAll(".growth-stack-card"));
      cards.forEach((card, i) => {
        if (i === cards.length - 1) return;
        const innerArticle = card.querySelector("article");
        if (!innerArticle) return;

        ScrollTrigger.create({
          trigger: card,
          start: "top top",
          endTrigger: cards[cards.length - 1],
          end: "top top",
          pin: true,
          pinSpacing: false,
        });

        gsap.to(innerArticle, {
          scale: 0.9,
          opacity: 0,
          y: -40,
          ease: "none",
          scrollTrigger: {
            trigger: cards[i + 1],
            start: "top bottom",
            end: "top top",
            scrub: true,
          },
        });
      });
    }
  });

  window.addEventListener("resize", () => ScrollTrigger.refresh());
</script>
