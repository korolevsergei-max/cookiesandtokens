---
/**
 * TokenSide — "How We Work"
 * The method, not a service bucket: Cookie (human) x Token (AI) and what the
 * pairing delivers. Dark navy; teal accents. Mirror of CookieSide layout.
 */

const services = [
  {
    number: "01",
    title: "The Cookie",
    desc: "Experience, taste, and the strategic read on your problem before anyone touches a brief or a line of code.",
    tags: ["Experience", "Taste", "Strategy", "Judgment"],
  },
  {
    number: "02",
    title: "The Token",
    desc: "Woven through creative, growth, and software so we move faster and explore wider without thinning the bar.",
    tags: ["Speed", "Scale", "Automation", "AI Agents"],
  },
  {
    number: "03",
    title: "The Result",
    desc: "More output, higher quality, and the judgment to know what is working, made by people who decide what is good. Faster, and yours.",
    tags: ["Faster", "Higher Quality", "Yours", "One Studio"],
  },
];
---

<section
  id="token"
  class="token-side"
  data-token-side
  data-tone="dark"
  aria-labelledby="token-title"
>
  <div class="token-side__header section-shell">
    <p class="eyebrow token-side__eyebrow">How We Work</p>
    <h2 id="token-title" class="token-side__headline">
      How the work<br /><span class="token-side__accent">gets made.</span>
    </h2>
    <p class="token-side__sub">
      People with real experience own the thinking and the final call. AI
      handles the speed and the volume. Every piece is reviewed by a person
      before it reaches you. That is the whole method.
    </p>
  </div>

  <div class="token-side__grid section-shell">
    {services.map((s) => (
      <article class="token-card" data-token-card>
        <span class="token-card__num">{s.number}</span>
        <h3 class="token-card__title">{s.title}</h3>
        <p class="token-card__desc">{s.desc}</p>
        <ul class="token-card__tags" aria-label="Service tags">
          {s.tags.map((t) => <li class="token-card__tag">{t}</li>)}
        </ul>
        <span class="token-card__glow" aria-hidden="true"></span>
      </article>
    ))}
  </div>

  <!-- Teal accent blob -->
  <div class="token-side__bg" aria-hidden="true">
    <span class="token-side__blob"></span>
  </div>
</section>

<style>
  .token-side {
    position: relative;
    background-color: var(--color-navy-800);
    color: var(--color-cream);
    overflow: clip;
    isolation: isolate;
  }

  .token-side__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .token-side__blob {
    position: absolute;
    bottom: -20vmax;
    left: -20vmax;
    width: 55vmax;
    height: 55vmax;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-teal) 0%, transparent 60%);
    filter: blur(120px);
    opacity: 0.1;
  }

  .token-side__header {
    position: relative;
    z-index: 1;
    padding-bottom: 0;
    max-width: 52rem;
  }
  .token-side__eyebrow {
    color: var(--color-teal);
  }
  .token-side__headline {
    font-size: var(--text-display-xl);
    line-height: var(--text-display-xl--line-height);
    letter-spacing: var(--text-display-xl--letter-spacing);
    margin-top: 0.5rem;
  }
  .token-side__accent {
    color: var(--color-teal);
  }
  .token-side__sub {
    max-width: 34rem;
    font-size: var(--text-lead);
    line-height: var(--text-lead--line-height);
    color: color-mix(in srgb, var(--color-cream) 65%, transparent);
    margin-top: 1rem;
  }

  /* ---------- Card grid ---------- */
  .token-side__grid {
    position: relative;
    z-index: 1;
    padding-top: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: 1.25rem;
  }

  .token-card {
    position: relative;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    background: color-mix(in srgb, var(--color-navy-700) 70%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-teal) 14%, transparent);
    border-radius: var(--radius-card);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    overflow: clip;
    transition:
      border-color var(--duration-base) var(--ease-out-soft),
      transform    var(--duration-base) var(--ease-out-soft);
    will-change: transform;
  }
  .token-card:hover {
    border-color: color-mix(in srgb, var(--color-teal) 45%, transparent);
    transform: translateY(-3px);
  }

  .token-card__glow {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      circle at var(--gx, 50%) var(--gy, 50%),
      color-mix(in srgb, var(--color-teal) 10%, transparent) 0%,
      transparent 65%
    );
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out-soft);
    pointer-events: none;
  }
  .token-card:hover .token-card__glow {
    opacity: 1;
  }

  .token-card__num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--color-teal);
  }
  .token-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.1;
  }
  .token-card__desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-cream) 62%, transparent);
    flex: 1;
  }

  .token-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
    margin-top: auto;
  }
  .token-card__tag {
    padding: 0.2rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-teal-deep);
    background: color-mix(in srgb, var(--color-teal) 10%, transparent);
    border-radius: var(--radius-pill);
  }
</style>

<script>
  import { reveal } from "../lib/reveal";
  import { prefersReducedMotion, isCoarsePointer } from "../lib/motion";

  const root = document.querySelector<HTMLElement>("[data-token-side]");
  if (root) initTokenSide(root);

  function initTokenSide(root: HTMLElement) {
    const cards = Array.from(root.querySelectorAll<HTMLElement>("[data-token-card]"));

    reveal(cards, { trigger: root.querySelector(".token-side__grid") });

    if (prefersReducedMotion() || isCoarsePointer()) return;

    cards.forEach((card) => {
      card.addEventListener("pointermove", (e: PointerEvent) => {
        const r = card.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width) * 100;
        const y = ((e.clientY - r.top) / r.height) * 100;
        card.style.setProperty("--gx", `${x}%`);
        card.style.setProperty("--gy", `${y}%`);
      });
    });
  }
</script>
