---
import { getCaseStudyHref, type CaseStudy } from "../data/caseStudies";

interface Props {
  previous?: CaseStudy;
  next?: CaseStudy;
}

const { previous, next } = Astro.props;
---

<nav class="story-pager" aria-label="More case studies">
  <div class="story-pager__inner">
    {
      previous ? (
        <a href={getCaseStudyHref(previous)} class="story-pager__link story-pager__link--prev" data-cursor="link">
          <span>Previous story</span>
          <strong>{previous.title}</strong>
        </a>
      ) : (
        <span></span>
      )
    }

    {
      next ? (
        <a href={getCaseStudyHref(next)} class="story-pager__link story-pager__link--next" data-cursor="link">
          <span>Next story</span>
          <strong>{next.title}</strong>
        </a>
      ) : (
        <span></span>
      )
    }
  </div>
</nav>

<style>
  .story-pager {
    padding-inline: var(--spacing-gutter);
    padding-block: clamp(3rem, 8vh, 6rem);
    color: var(--color-ink);
    background: var(--color-cream);
  }

  .story-pager__inner {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1rem, 3vw, 2rem);
    max-width: 88rem;
    margin-inline: auto;
  }

  .story-pager__link {
    display: grid;
    gap: 0.65rem;
    min-height: 12rem;
    padding: clamp(1.25rem, 3vw, 2rem);
    color: inherit;
    background: color-mix(in srgb, var(--color-navy) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-navy) 10%, transparent);
    border-radius: clamp(1rem, 2vw, 1.5rem);
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-out-soft),
      transform var(--duration-fast) var(--ease-out-soft);
  }

  .story-pager__link:hover,
  .story-pager__link:focus-visible {
    background: color-mix(in srgb, var(--color-teal) 13%, var(--color-cream));
    transform: translateY(-2px);
  }

  .story-pager__link--next {
    text-align: right;
  }

  .story-pager__link span {
    color: var(--color-purple-deep);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .story-pager__link strong {
    align-self: end;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.8rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1;
  }

  @media (max-width: 700px) {
    .story-pager__inner {
      grid-template-columns: minmax(0, 1fr);
    }

    .story-pager__link--next {
      text-align: left;
    }
  }
</style>
